@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Inscripciones.Views;

<h1>Datos del Cónyuge</h1>
<p>Paso 2 de 3 — La persona no se encontró registrada. Complete los datos a continuación.</p>

<form action="/inscripciones/formulario-pareja/@Model.InscripcionId" method="post">

    @await Html.PartialAsync("_PersonaFields", new PersonaFieldsViewModel
    {
        Prefix = "",
        IdentificacionHabilitada = true,
        TipoIdentificacion = Model.TipoIdentificacion,
        NumeroIdentificacion = Model.NumeroIdentificacion,
        MostrarRelacion = false
    })

    <div style="margin-top: 1rem; display: flex; gap: 1rem;">
        <button type="submit">Guardar pareja y continuar</button>
        <a href="/inscripciones/detalles/@Model.InscripcionId">Viajo solo - Terminar pre-inscripción</a>
    </div>

</form>