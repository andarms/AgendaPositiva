@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Inscripciones.Views;

<h1>Formulario de Inscripción</h1>

<form action="/inscripciones/formulario" method="post">


    @await Html.PartialAsync("_PersonaFields", new PersonaFieldsViewModel
    {
        Prefix = "",
        IdentificacionHabilitada = true,
        TipoIdentificacion = Model.TipoIdentificacion.ToString(),
        NumeroIdentificacion = Model.NumeroIdentificacion.ToString(),
        MostrarRelacion = false
    })

    <div class="form-control">
        <input type="checkbox" id="requiereHospedaje" name="RequiereHospedaje" value="true">
        <label for="requiereHospedaje">¿Requiere hospedaje?</label>
    </div>

    <div id="detallesHospedaje" style="display: none;">

        @* Esposa/o *@
        <div class="form-control">
            <input type="checkbox" id="viajaConEsposa" name="ViajaConEsposa" value="true">
            <label for="viajaConEsposa">¿Viajas con tu esposo o esposa?</label>
        </div>
        <div id="seccionEsposa" style="display: none;">
            <h3>Datos del cónyuge</h3>
            <div class="buscar-familiar" data-prefix="Esposa">
                <div class="buscar-familiar__form">
                    <div class="form-control">
                        <label>Tipo de Identificación:</label>
                        <select class="buscar-tipo">
                            @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
                            {
                                <option value="@tipo">@tipo.Humanize()</option>
                            }
                        </select>
                    </div>
                    <div class="form-control">
                        <label>Número de Identificación:</label>
                        <input type="text" inputmode="numeric" class="buscar-numero">
                    </div>
                    <button type="button" onclick="buscarFamiliar(this.closest('.buscar-familiar'))">Buscar</button>
                </div>
                <div class="buscar-familiar__resultado" style="display:none;"></div>
                <div class="buscar-familiar__campos" style="display:none;">
                    @await Html.PartialAsync(partialViewName: "_PersonaFields", new PersonaFieldsViewModel
                    {
                        Prefix = "Esposa",
                        IdentificacionHabilitada = false,
                        MostrarRelacion = false
                    })
                </div>
            </div>
        </div>

        @* Hijos *@
        <div class="form-control">
            <input type="checkbox" id="viajaConHijos" name="ViajaConHijos" value="true">
            <label for="viajaConHijos">¿Viajas con tus hijos?</label>
        </div>
        <div id="seccionHijos" style="display: none;">
            <h3>Datos de los hijos</h3>
            <div id="listaHijos"></div>
            <button type="button" onclick="agregarHijo()">+ Agregar hijo</button>
        </div>

        @* Otros familiares *@
        <div class="form-control">
            <input type="checkbox" id="viajaConOtrosFamiliares" name="ViajaConOtrosFamiliares" value="true">
            <label for="viajaConOtrosFamiliares">¿Viajas con algún otro familiar?</label>
        </div>
        <div id="seccionOtrosFamiliares" style="display: none;">
            <h3>Datos de otros familiares</h3>
            <div id="listaOtrosFamiliares"></div>
            <button type="button" onclick="agregarOtroFamiliar()">+ Agregar familiar</button>
        </div>
    </div>

    <button type="submit">Enviar Pre-Inscripción</button>

</form>

@* Template oculto para hijo *@
<template id="templateHijo">
    <fieldset class="familiar-fieldset">
        <legend>Hijo #<span class="familiar-index"></span></legend>
        <input type="hidden" name="Hijos.Index" value="__INDEX__">
        <div class="buscar-familiar" data-prefix="Hijos[__INDEX__]">
            <div class="buscar-familiar__form">
                <div class="form-control">
                    <label>Tipo de Identificación:</label>
                    <select class="buscar-tipo">
                        @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
                        {
                            <option value="@tipo">@tipo.Humanize()</option>
                        }
                    </select>
                </div>
                <div class="form-control">
                    <label>Número de Identificación:</label>
                    <input type="text" inputmode="numeric" class="buscar-numero">
                </div>
                <button type="button" onclick="buscarFamiliar(this.closest('.buscar-familiar'))">Buscar</button>
            </div>
            <div class="buscar-familiar__resultado" style="display:none;"></div>
            <div class="buscar-familiar__campos" style="display:none;">
                @await Html.PartialAsync("_PersonaFields", new PersonaFieldsViewModel
                {
                    Prefix = "Hijos[__INDEX__]",
                    IdentificacionHabilitada = false,
                    MostrarRelacion = false
                })
            </div>
        </div>
        <button type="button" onclick="eliminarFamiliar(this)">Eliminar</button>
    </fieldset>
</template>

@* Template oculto para otro familiar *@
<template id="templateOtroFamiliar">
    <fieldset class="familiar-fieldset">
        <legend>Familiar #<span class="familiar-index"></span></legend>
        <input type="hidden" name="OtrosFamiliares.Index" value="__INDEX__">
        <div class="buscar-familiar" data-prefix="OtrosFamiliares[__INDEX__]" data-mostrar-relacion="true">
            <div class="buscar-familiar__form">
                <div class="form-control">
                    <label>Tipo de Identificación:</label>
                    <select class="buscar-tipo">
                        @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
                        {
                            <option value="@tipo">@tipo.Humanize()</option>
                        }
                    </select>
                </div>
                <div class="form-control">
                    <label>Número de Identificación:</label>
                    <input type="text" inputmode="numeric" class="buscar-numero">
                </div>
                <button type="button" onclick="buscarFamiliar(this.closest('.buscar-familiar'))">Buscar</button>
            </div>
            <div class="buscar-familiar__resultado" style="display:none;"></div>
            <div class="buscar-familiar__campos" style="display:none;">
                @await Html.PartialAsync("_PersonaFields", new PersonaFieldsViewModel
                {
                    Prefix = "OtrosFamiliares[__INDEX__]",
                    IdentificacionHabilitada = false,
                    MostrarRelacion = true
                })
            </div>
        </div>
        <button type="button" onclick="eliminarFamiliar(this)">Eliminar</button>
    </fieldset>
</template>

<script>
    // Toggle secciones — habilita/deshabilita required en inputs ocultos
    function toggleSection(checkboxId, sectionId) {
        const cb = document.getElementById(checkboxId);
        const section = document.getElementById(sectionId);
        cb.addEventListener('change', function () {
            const visible = this.checked;
            section.style.display = visible ? 'block' : 'none';
            section.querySelectorAll('input[required], select[required], textarea[required]').forEach(el => {
                el.disabled = !visible;
            });
            // Los campos dentro de .buscar-familiar__campos empiezan ocultos;
            // mantenerlos deshabilitados hasta que la búsqueda los active.
            if (visible) {
                section.querySelectorAll('.buscar-familiar__campos').forEach(c => {
                    if (c.style.display === 'none') {
                        c.querySelectorAll('input[required], select[required], textarea[required]').forEach(el => el.disabled = true);
                    }
                });
            }
        });
        // Estado inicial: deshabilitar campos en secciones ocultas
        section.querySelectorAll('input[required], select[required], textarea[required]').forEach(el => {
            el.disabled = true;
        });
    }

    toggleSection('requiereHospedaje', 'detallesHospedaje');
    toggleSection('viajaConEsposa', 'seccionEsposa');
    toggleSection('viajaConHijos', 'seccionHijos');
    toggleSection('viajaConOtrosFamiliares', 'seccionOtrosFamiliares');

    // Contadores para índices (solo crecen, no se reutilizan — el hidden .Index resuelve el binding)
    let contadorHijos = 0;
    let contadorOtros = 0;

    function agregarDesdeTemplate(templateId, containerId, counter) {
        const template = document.getElementById(templateId);
        const container = document.getElementById(containerId);
        const html = template.innerHTML.replaceAll('__INDEX__', counter);
        container.insertAdjacentHTML('beforeend', html);
        // Actualizar el número visible en la leyenda
        const fieldsets = container.querySelectorAll('fieldset');
        fieldsets.forEach((fs, i) => {
            const span = fs.querySelector('.familiar-index');
            if (span) span.textContent = i + 1;
        });
    }

    function agregarHijo() {
        agregarDesdeTemplate('templateHijo', 'listaHijos', contadorHijos);
        contadorHijos++;
    }

    function agregarOtroFamiliar() {
        agregarDesdeTemplate('templateOtroFamiliar', 'listaOtrosFamiliares', contadorOtros);
        contadorOtros++;
    }

    function eliminarFamiliar(btn) {
        const fieldset = btn.closest('fieldset');
        const container = fieldset.parentElement;
        fieldset.remove();
        // Renumerar leyendas visibles
        container.querySelectorAll('fieldset').forEach((fs, i) => {
            const span = fs.querySelector('.familiar-index');
            if (span) span.textContent = i + 1;
        });
    }

    // --- Búsqueda de familiar existente ---

    async function buscarFamiliar(container) {
        const tipoSelect = container.querySelector('.buscar-tipo');
        const numeroInput = container.querySelector('.buscar-numero');
        const tipo = tipoSelect.value;
        const numero = numeroInput.value.trim();

        if (!numero) {
            alert('Ingrese el número de identificación.');
            return;
        }

        const resultadoDiv = container.querySelector('.buscar-familiar__resultado');
        const camposDiv = container.querySelector('.buscar-familiar__campos');
        const formDiv = container.querySelector('.buscar-familiar__form');
        const prefix = container.dataset.prefix;

        try {
            const resp = await fetch(`/inscripciones/buscar-persona?tipoIdentificacion=${encodeURIComponent(tipo)}&numeroIdentificacion=${encodeURIComponent(numero)}`);

            if (resp.ok) {
                const persona = await resp.json();
                // Persona encontrada — mostrar tarjeta resumen
                formDiv.style.display = 'none';
                camposDiv.style.display = 'none';
                // Deshabilitar fields ocultos para que no se envíen como required
                camposDiv.querySelectorAll('input[required], select[required], textarea[required]').forEach(el => el.disabled = true);

                const mostrarRelacion = container.dataset.mostrarRelacion === 'true';
                const relacionHtml = mostrarRelacion ? `
                    <div class="form-control">
                        <label>Parentesco:</label>
                        <select name="${prefix}.RelacionConLider" required>
                            @foreach (RelacionConLider rel in Enum.GetValues<RelacionConLider>())
                            {
                                    <option value="@rel">@rel.Humanize()</option>
                            }
                        </select>
                    </div>` : '';

                resultadoDiv.innerHTML = `
                    <div class="persona-encontrada">
                        <p><strong>Persona encontrada:</strong></p>
                        <dl>
                            <dt>Nombre</dt><dd>${persona.nombres} ${persona.apellidos}</dd>
                            <dt>Identificación</dt><dd>${persona.tipoIdentificacion} - ${persona.numeroIdentificacion}</dd>
                            <dt>Género</dt><dd>${persona.genero}</dd>
                            <dt>Fecha de Nacimiento</dt><dd>${persona.fechaNacimiento}</dd>
                            <dt>Teléfono</dt><dd>${persona.telefono}</dd>
                            <dt>Correo</dt><dd>${persona.email || '—'}</dd>
                        </dl>
                        ${relacionHtml}
                        <input type="hidden" name="${prefix}.PersonaExistenteId" value="${persona.id}">
                        <input type="hidden" name="${prefix}.Nombres" value="${persona.nombres}">
                        <input type="hidden" name="${prefix}.Apellidos" value="${persona.apellidos}">
                        <input type="hidden" name="${prefix}.Genero" value="${persona.genero}">
                        <input type="hidden" name="${prefix}.FechaNacimiento" value="${persona.fechaNacimiento}">
                        <input type="hidden" name="${prefix}.Telefono" value="${persona.telefono}">
                        <input type="hidden" name="${prefix}.Email" value="${persona.email || ''}">
                        <input type="hidden" name="${prefix}.TipoIdentificacion" value="${persona.tipoIdentificacion}">
                        <input type="hidden" name="${prefix}.NumeroIdentificacion" value="${persona.numeroIdentificacion}">
                        <button type="button" onclick="resetearBusqueda(this.closest('.buscar-familiar'))">Cambiar</button>
                    </div>`;
                resultadoDiv.style.display = 'block';
            } else if (resp.status === 404) {
                // Persona no encontrada — mostrar formulario de campos
                formDiv.style.display = 'none';
                resultadoDiv.innerHTML = `
                    <p>Persona no registrada. Complete los datos a continuación.</p>
                    <button type="button" onclick="resetearBusqueda(this.closest('.buscar-familiar'))">Buscar otro documento</button>`;
                resultadoDiv.style.display = 'block';
                camposDiv.style.display = 'block';
                // Habilitar campos y pre-llenar identificación
                camposDiv.querySelectorAll('input[required], select[required], textarea[required]').forEach(el => el.disabled = false);
                const tipoField = camposDiv.querySelector(`[name="${prefix}.TipoIdentificacion"]`);
                const numField = camposDiv.querySelector(`[name="${prefix}.NumeroIdentificacion"]`);
                if (tipoField) tipoField.value = tipo;
                if (numField) numField.value = numero;
            } else {
                alert('Error al buscar. Intente de nuevo.');
            }
        } catch {
            alert('Error de conexión. Intente de nuevo.');
        }
    }

    function resetearBusqueda(container) {
        const formDiv = container.querySelector('.buscar-familiar__form');
        const resultadoDiv = container.querySelector('.buscar-familiar__resultado');
        const camposDiv = container.querySelector('.buscar-familiar__campos');

        resultadoDiv.innerHTML = '';
        resultadoDiv.style.display = 'none';
        camposDiv.style.display = 'none';
        // Limpiar y deshabilitar campos del formulario de persona
        camposDiv.querySelectorAll('input, select, textarea').forEach(el => {
            if (el.type !== 'hidden') el.value = '';
            el.disabled = true;
        });
        // Limpiar campo de búsqueda
        container.querySelector('.buscar-numero').value = '';
        formDiv.style.display = 'block';
    }
</script>