@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Inscripciones.Views;
@using AgendaPositiva.Web.Features.Inscripciones.Views.ViewModels;

<h1>Datos del Familiar</h1>
<p>Paso 2 de 2 — La persona no se encontró registrada. Complete los datos a continuación.</p>

<form action="/inscripciones/formulario-familiar/@Model.InscripcionId" method="post">

    @await Html.PartialAsync("_PersonaFields", new PersonaFieldsViewModel
    {
        Prefix = "",
        IdentificacionHabilitada = true,
        TipoIdentificacion = Model.TipoIdentificacion,
        NumeroIdentificacion = Model.NumeroIdentificacion,
        MostrarRelacion = true,
        DepartamentoDefault = Model.DepartamentoDefault,
        CiudadDefault = Model.CiudadDefault
    })

    <div class="btn-group">
        <button type="submit">Guardar familiar y agregar otro</button>
        <a href="/inscripciones/verificar-familiares/@Model.InscripcionId" class="btn btn-secondary">Buscar otra
            persona</a>
            <a href="/inscripciones/detalles/@Model.InscripcionId" class="btn btn-secondary">Terminar pre-inscripción</a>
        </div>
    </form>