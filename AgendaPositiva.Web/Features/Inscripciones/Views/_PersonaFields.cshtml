@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Inscripciones.Views;
@model PersonaFieldsViewModel
@{
    string prefix = Model.Prefix;
    string dot = string.IsNullOrEmpty(prefix) ? "" : ".";
    string name(string field) => $"{prefix}{dot}{field}";
    string id(string field) => name(field).Replace(".", "_").Replace("[", "_").Replace("]", "_");
}

<div class="form-control">
    <label for="@id("Nombres")">Nombres:</label>
    <input type="text" id="@id("Nombres")" name="@name("Nombres")" required>
</div>

<div class="form-control">
    <label for="@id("Apellidos")">Apellidos:</label>
    <input type="text" id="@id("Apellidos")" name="@name("Apellidos")" required>
</div>

<div class="form-control">
    <label for="@id("Genero")">Género:</label>
    <select id="@id("Genero")" name="@name("Genero")" required>
        @foreach (Genero genero in Enum.GetValues<Genero>())
        {
            <option value="@genero">@genero.Humanize()</option>
        }
    </select>
</div>

<div class="form-control">
    <label for="@id("TipoIdentificacion")">Tipo de Identificación:</label>
    @if (Model.IdentificacionHabilitada)
    {
        <select id="@id("TipoIdentificacion")" disabled>
            @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
            {
                <option value="@tipo" selected="@(tipo.ToString() == Model.TipoIdentificacion)">@tipo.Humanize()</option>
            }
        </select>
        <input type="hidden" name="@name("TipoIdentificacion")" value="@Model.TipoIdentificacion">
    }
    else
    {
        <select id="@id("TipoIdentificacion")" name="@name("TipoIdentificacion")" required>
            @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
            {
                <option value="@tipo">@tipo.Humanize()</option>
            }
        </select>
    }
</div>

<div class="form-control">
    <label for="@id("NumeroIdentificacion")">Número de Identificación:</label>
    @if (Model.IdentificacionHabilitada)
    {
        <input type="text" inputmode="numeric" id="@id("NumeroIdentificacion")" disabled value="@Model.NumeroIdentificacion"
               required>
        <input type="hidden" name="@name("NumeroIdentificacion")" value="@Model.NumeroIdentificacion">
    }
    else
    {
        <input type="text" inputmode="numeric" id="@id("NumeroIdentificacion")" name="@name("NumeroIdentificacion")"
               required>
    }
</div>

<div class="form-control">
    <label for="@id("FechaNacimiento")">Fecha de Nacimiento:</label>
    <input type="date" id="@id("FechaNacimiento")" name="@name("FechaNacimiento")" required>
</div>

<div class="form-control">
    <label for="@id("Telefono")">Teléfono:</label>
    <input type="tel" id="@id("Telefono")" name="@name("Telefono")" required>
</div>

<div class="form-control">
    <label for="@id("Email")">Correo Electrónico:</label>
    <input type="email" id="@id("Email")" name="@name("Email")">
</div>

<div class="form-control">
    <label for="@id("NecesidadesEspeciales")">Necesidades Especiales:</label>
    <textarea id="@id("NecesidadesEspeciales")" name="@name("NecesidadesEspeciales")"></textarea>
</div>

@if (Model.MostrarRelacion)
{
    <div class="form-control">
        <label for="@id("RelacionConLider")">Parentesco:</label>
        <select id="@id("RelacionConLider")" name="@name("RelacionConLider")" required>
            @foreach (RelacionConLider rel in Enum.GetValues<RelacionConLider>())
            {
                <option value="@rel">@rel.Humanize()</option>
            }
        </select>
    </div>
}
</div>