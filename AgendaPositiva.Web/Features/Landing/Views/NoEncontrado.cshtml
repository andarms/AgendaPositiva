@{
    Layout = "~/Features/Landing/Views/_Layout.cshtml";
}

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        font-family: 'Montserrat', sans-serif;
        text-align: center;
        background: #f8f9fa;
        padding: 2rem;
    }

    .not-found h1 {
        font-size: 6rem;
        font-weight: 800;
        color: #1a1a2e;
        margin: 0;
        line-height: 1;
    }

    .not-found p {
        font-size: 1.2rem;
        color: #555;
        margin: 1rem 0 2rem;
    }

    .not-found a {
        display: inline-block;
        padding: .75rem 2rem;
        background: #1a1a2e;
        color: #fff;
        border-radius: 6px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        transition: background .15s ease;
    }

    .not-found a:hover {
        background: #2d2d44;
    }
</style>

<div class="not-found">
    <h1>404</h1>
    <p>La página que buscas no existe o fue movida.</p>
    <a href="/">Volver al inicio</a>
</div>
