@using AgendaPositiva.Web.Features.Admin.Auditoria;
@model List<AuditoriaAdmin>

@{
    var filtroUsuario = ViewBag.FiltroUsuario as string;
    var filtroAccion = ViewBag.FiltroAccion as string;
    var acciones = ViewBag.AccionesDisponibles as List<string> ?? [];
    int pagina = ViewBag.Pagina;
    int porPagina = ViewBag.PorPagina;
    int totalPaginas = ViewBag.TotalPaginas;
    int totalRegistros = ViewBag.TotalRegistros;

    string BuildPageUrl(int pag, int? porPaginaOverride = null)
    {
        var qs = new Dictionary<string, string?>
        {
            ["usuario"] = filtroUsuario,
            ["accion"] = filtroAccion,
            ["pagina"] = pag.ToString(),
            ["porPagina"] = (porPaginaOverride ?? porPagina).ToString(),
        };
        var pairs = qs
            .Where(kv => !string.IsNullOrEmpty(kv.Value))
            .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value!)}");
        var query = string.Join("&", pairs);
        return "/admin/auditoria" + (query.Length > 0 ? "?" + query : "");
    }
}

<h1>Historial de Auditoría</h1>
<div class="page-header">
    <p class="text-secondary">
        <strong>@totalRegistros</strong> registros
    </p>
</div>

<form method="get" action="/admin/auditoria" class="card filter-form">
    <div class="filter-grid">
        <div>
            <label class="form-label">Usuario</label>
            <input type="text" name="usuario" value="@filtroUsuario" placeholder="Buscar por usuario..."
                   class="form-control" />
        </div>
        <div>
            <label class="form-label">Acción</label>
            <select name="accion" class="form-control">
                <option value="">Todas</option>
                @foreach (var acc in acciones)
                {
                    <option value="@acc" selected="@(filtroAccion == acc)">@acc</option>
                }
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn btn--primary">Buscar</button>
            <a href="/admin/auditoria" class="btn btn--secondary">Limpiar</a>
        </div>
    </div>
</form>

<div class="table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Fecha</th>
                <th>Usuario</th>
                <th>Inscripción</th>
                <th>Acción</th>
                <th>Valor anterior</th>
                <th>Valor nuevo</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var reg = Model[i];
                var offset = (pagina - 1) * porPagina;
                <tr>
                    <td class="col-index">@(offset + i + 1)</td>
                    <td class="col-date">@reg.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@reg.Usuario</td>
                    <td><a href="/admin/inscripciones/@reg.InscripcionId">#@reg.InscripcionId</a></td>
                    <td>@reg.Accion</td>
                    <td>@(reg.ValorAnterior ?? "—")</td>
                    <td>@(reg.ValorNuevo ?? "—")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (totalRegistros > 0)
{
    <div class="pagination">
        <div class="pagination__info">
            Mostrando @((pagina - 1) * porPagina + 1)–@(Math.Min(pagina * porPagina, totalRegistros)) de @totalRegistros
        </div>
        <div class="pagination__controls">
            @if (pagina > 1)
            {
                <a href="@BuildPageUrl(pagina - 1)" class="btn btn--secondary">← Anterior</a>
            }
            <span class="pagination__current">Página @pagina de @totalPaginas</span>
            @if (pagina < totalPaginas)
            {
                <a href="@BuildPageUrl(pagina + 1)" class="btn btn--secondary">Siguiente →</a>
            }
        </div>
        <div class="pagination__size">
            @foreach (var size in new[] { 10, 50, 100 })
            {
                if (size == porPagina)
                {
                    <span class="btn btn--primary">@size</span>
                }
                else
                {
                    <a href="@BuildPageUrl(1, size)" class="btn btn--secondary">@size</a>
                }
            }
        </div>
    </div>
}

@if (Model.Count == 0)
{
    <p class="text-secondary" style="text-align: center; margin-top: 2rem;">No se encontraron registros.</p>
}
