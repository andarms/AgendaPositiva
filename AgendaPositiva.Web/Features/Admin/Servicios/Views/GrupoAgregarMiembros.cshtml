@using AgendaPositiva.Web.Features.Admin.Servicios
@using AgendaPositiva.Web.Features.Commons
@model GrupoAgregarMiembrosViewModel

<nav class="breadcrumb">
    <a href="/admin">Admin</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios">Servicios</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios/@Model.ServicioId/grupos">@Model.ServicioNombre</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios/grupos/@Model.GrupoId">@Model.GrupoNombre</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">Agregar Miembros</span>
</nav>

<h1>Agregar Miembros — @Model.GrupoNombre</h1>

<form method="post">
    <div class="card" style="margin-bottom:1.5rem;">
        <div style="padding:1.25rem;">
            <!-- Filtros -->
            <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-bottom:1rem;">
                <div>
                    <label class="form-label" style="font-size:0.85rem;">Buscar por nombre</label>
                    <input type="text" id="filtro-nombre" class="form-control" placeholder="Nombre o apellido..." />
                </div>
                <div>
                    <label class="form-label" style="font-size:0.85rem;">Buscar por documento</label>
                    <input type="text" id="filtro-documento" class="form-control" placeholder="Número de documento..." />
                </div>
                <div>
                    <label class="form-label" style="font-size:0.85rem;">Filtrar por servicio de inscripción</label>
                    <select id="filtro-servicio" class="form-control">
                        <option value="">— Todos —</option>
                        @foreach (ServicioInscripcion si in Enum.GetValues(typeof(ServicioInscripcion)))
                        {
                            <option value="@si">@si.Descripcion()</option>
                        }
                    </select>
                </div>
            </div>

            <div style="margin-bottom:0.75rem;display:flex;gap:0.75rem;align-items:center;">
                <span id="conteo-seleccionados" style="font-weight:600;">0 seleccionados</span>
                <button type="button" class="btn btn--secondary" onclick="toggleAll()"
                        style="font-size:0.85rem;">Seleccionar/Deseleccionar visibles</button>
            </div>

            <div class="table-wrapper" style="max-height:500px;overflow-y:auto;">
                <table class="admin-table" style="font-size:0.875rem;" id="tabla-inscripciones">
                    <thead style="position:sticky;top:0;z-index:1;">
                        <tr>
                            <th style="width:40px;"></th>
                            <th>Nombre</th>
                            <th>Documento</th>
                            <th>Edad</th>
                            <th>Localidad</th>
                            <th>Servicio Inscripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ins in Model.InscripcionesDisponibles)
                        {
                            var servicios = string.Join(", ", ins.Servicios.Select(s => s.Descripcion()));
                            var serviciosData = string.Join(",", ins.Servicios.Select(s => s.ToString()));
                            var yaEnGrupo = Model.IdsYaEnGrupo.Contains(ins.Id);
                            Model.GrupoDeOtros.TryGetValue(ins.Id, out var otroGrupo);
                            <tr class="fila-inscripcion" data-nombre="@ins.Persona.NombreCompleto.ToLower()"
                                data-documento="@ins.Persona.NumeroIdentificacion"
                                data-servicios="@serviciosData"
                                data-otro-grupo="@(otroGrupo ?? "")"
                                data-nombre-completo="@ins.Persona.NombreCompleto"
                                style="@(yaEnGrupo ? "opacity:0.55;" : "")">
                                <td>
                                    <input type="checkbox" name="miembrosIds" value="@ins.Id" class="cb-miembro"
                                           onchange="actualizarConteo();" @(yaEnGrupo ? "disabled" : "") />
                                </td>
                                <td>
                                    @ins.Persona.NombreCompleto
                                    @if (yaEnGrupo)
                                    {
                                        <span style="font-size:0.75rem;color:#718096;margin-left:0.35rem;">(ya en este grupo)</span>
                                    }
                                    else if (otroGrupo != null)
                                    {
                                        <span style="font-size:0.75rem;color:#d97706;margin-left:0.35rem;" title="@otroGrupo">⚠️ ya en otro grupo</span>
                                    }
                                </td>
                                <td>@ins.Persona.NumeroIdentificacion</td>
                                <td>@((int)ins.Persona.Edad)</td>
                                <td>@ins.Localidad</td>
                                <td>@(string.IsNullOrEmpty(servicios) ? "—" : servicios)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div style="display:flex;gap:0.5rem;">
        <button type="submit" class="btn btn--primary">Agregar Seleccionados</button>
        <a href="/admin/servicios/grupos/@Model.GrupoId" class="btn btn--secondary">Cancelar</a>
    </div>
</form>

<script>
    const filtroNombre = document.getElementById('filtro-nombre');
    const filtroDocumento = document.getElementById('filtro-documento');
    const filtroServicio = document.getElementById('filtro-servicio');
    const filas = document.querySelectorAll('.fila-inscripcion');

    function filtrar() {
        const nombre = filtroNombre.value.toLowerCase();
        const documento = filtroDocumento.value.toLowerCase();
        const servicio = filtroServicio.value;
        filas.forEach(fila => {
            const matchNombre = !nombre || fila.dataset.nombre.includes(nombre);
            const matchDocumento = !documento || fila.dataset.documento.toLowerCase().includes(documento);
            const matchServicio = !servicio || fila.dataset.servicios.split(',').includes(servicio);
            fila.style.display = (matchNombre && matchDocumento && matchServicio) ? '' : 'none';
        });
    }

    filtroNombre.addEventListener('input', filtrar);
    filtroDocumento.addEventListener('input', filtrar);
    filtroServicio.addEventListener('change', filtrar);

    function actualizarConteo() {
        const count = document.querySelectorAll('.cb-miembro:checked').length;
        document.getElementById('conteo-seleccionados').textContent = count + ' seleccionados';
    }

    function toggleAll() {
        const visibles = Array.from(filas).filter(f => f.style.display !== 'none');
        const allChecked = visibles.every(f => f.querySelector('.cb-miembro').checked);
        visibles.forEach(f => f.querySelector('.cb-miembro').checked = !allChecked);
        actualizarConteo();
    }

    // Confirmación al enviar si hay personas ya asignadas a otro grupo
    document.querySelector('form').addEventListener('submit', function (e) {
        const conflictos = [];
        document.querySelectorAll('.cb-miembro:checked').forEach(cb => {
            const fila = cb.closest('tr');
            const otroGrupo = fila.dataset.otroGrupo;
            const nombre = fila.dataset.nombreCompleto;
            if (otroGrupo) conflictos.push(`• ${nombre} (${otroGrupo})`);
        });
        if (conflictos.length === 0) return;
        e.preventDefault();
        const mensaje = 'Las siguientes personas ya están asignadas a otro grupo de servicio:\n\n'
            + conflictos.join('\n')
            + '\n\n¿Desea agregarlas de todas formas?';
        if (confirm(mensaje)) this.submit();
    });
</script>
