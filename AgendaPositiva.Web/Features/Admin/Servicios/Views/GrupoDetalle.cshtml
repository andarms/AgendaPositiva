@using AgendaPositiva.Web.Features.Admin.Servicios.Dominio
@using AgendaPositiva.Web.Features.Commons
@model GrupoServicio

<nav class="breadcrumb">
    <a href="/admin">Admin</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios">Servicios</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios/@Model.ServicioId/grupos">@Model.Servicio.Nombre</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">@Model.Nombre</span>
</nav>

<h1>@Model.Nombre</h1>

<div class="card" style="max-width:640px;margin-bottom:1.5rem;">
    <div style="padding:1.25rem;">
        <p style="margin:0 0 0.25rem;">
            <strong>Servicio:</strong> @Model.Servicio.Nombre
        </p>
        <p style="margin:0;">
            <strong>Horario:</strong> @(Model.HorarioServicio?.Descripcion ?? "—")
        </p>
    </div>
</div>

<div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
    <a href="/admin/servicios/grupos/@Model.Id/agregar-miembros" class="btn btn--primary">+ Agregar Personas</a>
    <a href="/admin/servicios/grupos/@Model.Id/editar" class="btn btn--secondary">Editar Grupo</a>
    <a href="/admin/servicios/@Model.ServicioId/grupos" class="btn btn--secondary">← Volver a Grupos</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="card" style="padding:1rem;border-left:4px solid #48BB78;margin-bottom:1rem;">
        @msg
    </div>
}

<!-- Miembros del grupo -->
<div class="card" style="padding:1.25rem;">
    <h2 style="margin-top:0;">Miembros del Grupo (@Model.Miembros.Count)</h2>

    @if (Model.Miembros.Count == 0)
    {
        <p style="color:#A0AEC0;margin:0;">Sin miembros asignados. Usa el botón "Agregar Personas" para añadir miembros al grupo.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table class="admin-table" style="font-size:0.9rem;">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Documento</th>
                        <th>Localidad</th>
                        <th>Rol</th>
                        <th style="width:180px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Miembros.OrderBy(m => m.Rol).ThenBy(m => m.Inscripcion.Persona.Nombres))
                    {
                        var noAsiste = m.Inscripcion.Estado == EstadoInscripcion.NoVaAsistir;
                        <tr style="@(noAsiste ? "background:#FFF5F5;" : "")" id="fila-miembro-@m.Id">
                            <td>
                                @m.Inscripcion.Persona.NombreCompleto
                                @if (noAsiste)
                                {
                                    <span class="badge badge--danger" style="margin-left:0.25rem;">No asiste</span>
                                }
                            </td>
                            <td>@m.Inscripcion.Persona.NumeroIdentificacion</td>
                            <td>@m.Inscripcion.Localidad</td>
                            <td>
                                <span class="badge @BadgeClass(m.Rol)" id="badge-rol-@m.Id">@m.Rol</span>
                            </td>
                            <td>
                                <div style="display:flex;gap:0.25rem;align-items:center;">
                                    <button type="button" class="btn btn--secondary" style="font-size:0.8rem;padding:0.25rem 0.5rem;"
                                            onclick="mostrarEdicionRol(@m.Id, '@m.Rol')">
                                        Cambiar Rol
                                    </button>
                                    <form method="post" action="/admin/servicios/miembros/@m.Id/remover"
                                          onsubmit="return confirm('¿Remover a @m.Inscripcion.Persona.NombreCompleto del grupo?');"
                                          style="margin:0;">
                                        <button type="submit" class="btn btn--danger" style="font-size:0.8rem;padding:0.25rem 0.5rem;">
                                            Remover
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Modal para cambiar rol -->
<div id="modal-rol" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;display:none;align-items:center;justify-content:center;">
    <div class="card" style="padding:1.5rem;min-width:320px;">
        <h3 style="margin-top:0;">Cambiar Rol</h3>
        <form method="post" id="form-cambiar-rol">
            <div style="margin-bottom:1rem;">
                <label class="form-label">Nuevo rol</label>
                <select name="rol" id="select-rol" class="form-control">
                    @foreach (RolMiembroGrupoServicio r in Enum.GetValues(typeof(RolMiembroGrupoServicio)))
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>
            <div style="display:flex;gap:0.5rem;">
                <button type="submit" class="btn btn--primary">Guardar</button>
                <button type="button" class="btn btn--secondary" onclick="cerrarModal()">Cancelar</button>
            </div>
        </form>
    </div>
</div>

<script>
    const modal = document.getElementById('modal-rol');
    const formCambiarRol = document.getElementById('form-cambiar-rol');
    const selectRol = document.getElementById('select-rol');

    function mostrarEdicionRol(miembroId, rolActual) {
        formCambiarRol.action = '/admin/servicios/miembros/' + miembroId + '/cambiar-rol';
        selectRol.value = rolActual;
        modal.style.display = 'flex';
    }

    function cerrarModal() {
        modal.style.display = 'none';
    }

    modal.addEventListener('click', function (e) {
        if (e.target === modal) cerrarModal();
    });
</script>

@functions {
    static string BadgeClass(RolMiembroGrupoServicio rol) => rol switch
    {
        RolMiembroGrupoServicio.Coordinador => "badge--info",
        RolMiembroGrupoServicio.Lider => "badge--warning",
        RolMiembroGrupoServicio.Servidor => "badge--success",
        _ => ""
    };
}
