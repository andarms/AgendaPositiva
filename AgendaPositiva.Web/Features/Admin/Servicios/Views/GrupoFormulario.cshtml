@using AgendaPositiva.Web.Features.Admin.Servicios
@using AgendaPositiva.Web.Features.Admin.Servicios.Dominio
@model GrupoFormViewModel

<nav class="breadcrumb">
    <a href="/admin">Admin</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios">Servicios</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios/@Model.ServicioId/grupos">@Model.ServicioNombre</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">@(Model.GrupoId == 0 ? "Crear Grupo" : "Editar Grupo")</span>
</nav>

<h1>@(Model.GrupoId == 0 ? "Nuevo Grupo" : "Editar Grupo") — @Model.ServicioNombre</h1>

<form method="post">
    <div class="card" style="max-width:640px;margin-bottom:1.5rem;">
        <div style="padding:1.25rem;">
            <div style="margin-bottom:1rem;">
                <label class="form-label">Nombre del grupo</label>
                <input type="text" name="nombre" value="@Model.Nombre" class="form-control" required />
            </div>
            <div style="margin-bottom:1rem;">
                <label class="form-label">Horario asignado</label>
                <select name="horarioServicioId" class="form-control" required>
                    <option value="">— Seleccionar horario —</option>
                    @foreach (var h in Model.Horarios)
                    {
                        <option value="@h.Id" @(h.Id == Model.HorarioServicioId ? "selected" : "")>
                            @h.Descripcion (@h.FechaHoraInicio.ToString("dd/MM HH:mm") - @h.FechaHoraFin.ToString("HH:mm"))
                        </option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div style="display:flex;gap:0.5rem;">
        <button type="submit" class="btn btn--primary">Guardar</button>
        @if (Model.GrupoId > 0)
        {
            <a href="/admin/servicios/grupos/@Model.GrupoId" class="btn btn--secondary">Cancelar</a>
        }
        else
        {
            <a href="/admin/servicios/@Model.ServicioId/grupos" class="btn btn--secondary">Cancelar</a>
        }
    </div>
</form>
