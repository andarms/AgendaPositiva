@using AgendaPositiva.Web.Features.Admin.Servicios.Dominio
@model Servicio

<nav class="breadcrumb">
    <a href="/admin">Admin</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios">Servicios</a>
    <span class="breadcrumb__separator">/</span>
    <a href="/admin/servicios/@Model.Id">@Model.Nombre</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">Ubicaciones</span>
</nav>

<h1>Ubicaciones: @Model.Nombre</h1>

<div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
    <a href="/admin/servicios/@Model.Id/ubicaciones/crear" class="btn btn--primary">+ Nueva Ubicación</a>
    <a href="/admin/servicios/@Model.Id" class="btn btn--secondary">← Volver al Servicio</a>
</div>

@if (TempData["Mensaje"] is string msg)
{
    <div class="card" style="padding:1rem;border-left:4px solid #48BB78;margin-bottom:1rem;">
        @msg
    </div>
}

@if (Model.Ubicaciones.Count == 0)
{
    <p>No hay ubicaciones registradas para este servicio.</p>
}
else
{
    <div class="card" style="padding:1.25rem;">
        <div class="table-wrapper">
            <table class="admin-table" style="font-size:0.9rem;">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th style="width:180px;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @{ var idx = 1; }
                    @foreach (var u in Model.Ubicaciones)
                    {
                        <tr>
                            <td>@(idx++)</td>
                            <td>@u.Nombre</td>
                            <td>
                                <div style="display:flex;gap:0.25rem;">
                                    <a href="/admin/servicios/@Model.Id/ubicaciones/@u.Id/editar"
                                       class="btn btn--secondary" style="font-size:0.8rem;padding:0.25rem 0.5rem;">
                                        Editar
                                    </a>
                                    <form method="post" action="/admin/servicios/@Model.Id/ubicaciones/@u.Id/eliminar"
                                          onsubmit="return confirm('¿Eliminar la ubicación @u.Nombre?');"
                                          style="margin:0;">
                                        <button type="submit" class="btn btn--danger"
                                                style="font-size:0.8rem;padding:0.25rem 0.5rem;">
                                            Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
