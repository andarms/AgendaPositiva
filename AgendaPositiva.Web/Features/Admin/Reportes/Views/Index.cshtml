@{
    Layout = "~/Features/Admin/Inscripciones/Views/_Layout.cshtml";
}

<div style="max-width:720px;">
    <h1 style="font-size:1.5rem;font-weight:600;margin-bottom:0.25rem;">Reportes</h1>
    <p style="color:#86868b;font-size:0.8125rem;margin-bottom:2rem;">Descarga reportes en Excel del evento activo.</p>

    <div style="background:#fff;border-radius:12px;padding:1.25rem;border:1px solid rgba(0,0,0,0.06);">
        <div style="display:flex;align-items:center;justify-content:space-between;">
            <div>
                <strong style="font-size:0.875rem;">Inscripción de Niños</strong>
                <p style="font-size:0.75rem;color:#86868b;margin-top:0.25rem;">
                    Nombre, edad, localidad, tipo de sangre, alergias y acudiente.
                </p>
            </div>
            <a href="/admin/reportes/ninos"
               style="display:inline-flex;align-items:center;gap:0.375rem;background:#1a1a2e;color:#fff;padding:0.5rem 1rem;border-radius:8px;font-size:0.75rem;font-weight:500;text-decoration:none;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Descargar
            </a>
        </div>
    </div>
</div>
