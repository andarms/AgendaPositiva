@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Admin.Inscripciones.Views.ViewModels;
@model ListaInscripcionesViewModel

<h1>Inscripciones — @Model.Evento.Nombre</h1>
<div class="page-header">
    <p class="text-secondary">
        @Model.Evento.FechaInicio.ToString("dd/MM/yyyy") — @Model.Evento.FechaFin.ToString("dd/MM/yyyy")
        · <strong>@Model.Inscripciones.Count</strong> inscripciones
    </p>
    <a href="/admin/inscripciones/exportar" class="btn btn--success">⬇ Exportar Excel</a>
</div>

<form method="get" action="/admin/inscripciones" class="card filter-form">
    @if (!string.IsNullOrEmpty(Model.SortLocalidad))
    {
        <input type="hidden" name="sortLocalidad" value="@Model.SortLocalidad" />
    }
    <div class="filter-grid">
        <div>
            <label class="form-label">Nombre</label>
            <input type="text" name="nombre" value="@Model.FiltroNombre" placeholder="Buscar por nombre..."
                   class="form-control" />
        </div>
        <div>
            <label class="form-label">Localidad</label>
            <select name="departamento" class="form-control">
                <option value="">Todos</option>
                @foreach (var dep in Model.Departamentos)
                {
                    <option value="@dep" selected="@(Model.FiltroDepartamento == dep)">@dep</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label">Estado</label>
            <select name="estado" class="form-control">
                <option value="">Todos</option>
                @foreach (EstadoInscripcion e in Enum.GetValues<EstadoInscripcion>())
                {
                    <option value="@e" selected="@(Model.FiltroEstado != null && Model.FiltroEstado == e)">
                        @e.Humanize()</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Hospedaje</label>
                <select name="hospedaje" class="form-control">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.FiltroHospedaje != null && Model.FiltroHospedaje == true)">Sí
                    </option>
                    <option value="false" selected="@(Model.FiltroHospedaje != null && Model.FiltroHospedaje == false)">No
                    </option>
                </select>
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn btn--primary">Buscar</button>
                <a href="/admin/inscripciones" class="btn btn--secondary">Limpiar</a>
            </div>
        </div>
    </form>

    @if (Model.Inscripciones.Count == 0)
    {
        <p>No hay inscripciones que coincidan con los filtros.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Identificación</th>
                        <th>
                            <a href="@Model.BuildSortUrl(Model.NextSortLocalidad)">Localidad@(Model.SortLocalidadIndicator)</a>
                        </th>
                        <th>Estado</th>
                        <th>Hospedaje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (inscripcion, index) in Model.Inscripciones.Select((i, idx) => (i, idx)))
                    {
                        var badgeCss = inscripcion.Estado switch
                        {
                            EstadoInscripcion.Completado => "badge--success",
                            EstadoInscripcion.Abono2 => "badge--abono2",
                            EstadoInscripcion.Abono1 => "badge--abono1",
                            EstadoInscripcion.Pendiente => "badge--warning",
                            EstadoInscripcion.NoVaAsistir => "badge--danger",
                            _ => "badge--muted"
                        };
                        <tr>
                            <td class="col-index">@(index + 1)</td>
                            <td class="col-name">
                                <a href="/admin/inscripciones/@inscripcion.Id">@inscripcion.Persona.NombreCompleto</a>
                            </td>
                            <td>@inscripcion.Persona.TipoIdentificacion.Humanize() — @inscripcion.Persona.NumeroIdentificacion</td>
                            <td>@inscripcion.Localidad</td>
                            <td><span class="badge @badgeCss">@inscripcion.Estado.Humanize()</span></td>
                            <td>@(inscripcion.RequiereHospedaje ? "Sí" : "No")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
