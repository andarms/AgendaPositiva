@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Admin.Inscripciones.Views.ViewModels;
@model ListaInscripcionesViewModel

<nav class="breadcrumb">
    <a href="/admin">Admin</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">Inscripciones</span>
</nav>

<h1>Inscripciones — @Model.Evento.Nombre</h1>

@if (Model.CupoInfo is not null)
{
    var cupo = Model.CupoInfo;
    var pct = cupo.CupoTotal > 0 ? (double)cupo.TotalInscritos / cupo.CupoTotal * 100 : 100;
    var barClass = pct >= 100 ? "cupo-bar__fill--full" : pct >= 80 ? "cupo-bar__fill--warn" : "cupo-bar__fill--ok";

    <style>
        .cupo-header-card {
            background: #fff;
            border-radius: 12px;
            padding: 1rem 1.5rem;
            margin-bottom: 1rem;
            border: 1px solid rgba(0,0,0,0.06);
        }
        .cupo-header-card__title {
            font-size: 0.8125rem;
            font-weight: 600;
            color: #1d1d1f;
            margin-bottom: 0.75rem;
        }
        .cupo-header-card__stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
            gap: 0.75rem 1rem;
            align-items: start;
        }
        .cupo-stat-item {
            text-align: center;
        }
        .cupo-stat-item__value {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1d1d1f;
            line-height: 1;
        }
        .cupo-stat-item__label {
            font-size: 0.625rem;
            color: #86868b;
            margin-top: 0.15rem;
        }
        .cupo-header-card__bar {
            margin-top: 0.75rem;
            width: 100%;
            height: 6px;
            background: rgba(0,0,0,0.06);
            border-radius: 3px;
            overflow: hidden;
        }
        .cupo-header-card__regions {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.75rem;
        }
        @@media (max-width: 480px) {
            .cupo-header-card {
                padding: 0.75rem 1rem;
            }
            .cupo-header-card__stats {
                grid-template-columns: repeat(3, 1fr);
                gap: 0.625rem 0.5rem;
            }
            .cupo-stat-item__value {
                font-size: 1.0625rem;
            }
        }
    </style>

    <div class="cupo-header-card">
        <div class="cupo-header-card__title">@cupo.NombreRegion</div>
        <div class="cupo-header-card__stats">
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value">@cupo.TotalInscritos</div>
                <div class="cupo-stat-item__label">Total inscritos</div>
            </div>
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value">@cupo.TotalBebes</div>
                <div class="cupo-stat-item__label">Bebés (0–2)</div>
            </div>
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value">@cupo.TotalNinos</div>
                <div class="cupo-stat-item__label">Niños (3–10)</div>
            </div>
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value">@cupo.TotalAdolescentes</div>
                <div class="cupo-stat-item__label">Adolescentes (11–17)</div>
            </div>
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value">@cupo.TotalAdultos</div>
                <div class="cupo-stat-item__label">Adultos (18+)</div>
            </div>
            @if (User.IsInRole("Administrador"))
            {
                <div class="cupo-stat-item">
                    <div class="cupo-stat-item__value" style="color:#007aff;">@(cupo.TotalAdolescentes + cupo.TotalAdultos)</div>
                    <div class="cupo-stat-item__label">Cupo Salón</div>
                </div>
            }
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value">@cupo.CupoTotal</div>
                <div class="cupo-stat-item__label">Cupo total</div>
            </div>
            <div class="cupo-stat-item">
                <div class="cupo-stat-item__value" style="color:@(cupo.CupoDisponible <= 0 ? "#ff3b30" : "#1d1d1f");">@cupo.CupoDisponible</div>
                <div class="cupo-stat-item__label">Disponible</div>
            </div>
        </div>
        <div class="cupo-header-card__bar">
            <div class="@barClass"
                 style="height:100%;border-radius:3px;width:@(Math.Min(pct, 100))%;@(pct >= 100 ? "background:#ff3b30;" : pct >= 80 ? "background:#ff9500;" : "background:#34c759;")">
            </div>
        </div>
        @if (cupo.Regiones.Count > 1)
        {
            <div class="cupo-header-card__regions">
                @foreach (var r in cupo.Regiones)
                    {
                        <span style="background:rgba(0,0,0,0.04);padding:0.15rem 0.5rem;border-radius:100px;color:#1d1d1f;">
                            @r.Nombre: @r.TotalInscritos/@r.Cupo
                        </span>
                    }
                </div>
            }
        </div>
    }

    <div class="page-header">
        <p class="text-secondary">
            @Model.Evento.FechaInicio.ToString("dd/MM/yyyy") — @Model.Evento.FechaFin.ToString("dd/MM/yyyy")
            · <strong>@Model.TotalInscripciones</strong> inscripciones
        </p>
    </div>

    <div class="action-bar">
        <a href="/admin/inscripciones/formulario/verificacion" class="btn btn--primary btn--lg">+ Nueva Inscripción</a>
        <a href="/admin/inscripciones/exportar" class="btn btn--success btn--lg">⬇ Exportar Excel</a>
    </div>

    @if (Model.Inscripciones.Count == 0)
    {
        <p>No hay inscripciones que coincidan con los filtros.</p>
    }
    else
    {
        <div class="table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Nombre</th>
                        <th>Identificación</th>
                        <th>
                            <a href="@Model.BuildSortUrl(Model.NextSortLocalidad)">Localidad@(Model.SortLocalidadIndicator)</a>
                        </th>
                        <th>Estado</th>
                        <th>Hospedaje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (inscripcion, index) in Model.Inscripciones.Select((i, idx) => (i, idx)))
                    {
                        var offset = (Model.Pagina - 1) * Model.PorPagina;
                        var totalAbonado = inscripcion.Abonos.Sum(a => a.Monto);
                        var precioCategoria = inscripcion.CategoriaInscripcion?.Precio ?? 0;
                        var pctPago = precioCategoria > 0 ? (double)(totalAbonado / precioCategoria) * 100 : 0;
                        var badgePago = pctPago >= 100 ? "badge--success" : pctPago >= 50 ? "badge--abono2" : pctPago > 0 ? "badge--abono1" : "badge--warning";
                        var textoPago = pctPago >= 100 ? "Completado" : pctPago > 0 ? $"Abono ({pctPago:F0}%)" : "Pendiente";
                        <tr>
                            <td class="col-index">@(offset + index + 1)</td>
                            <td class="col-name">
                                <a href="/admin/inscripciones/@inscripcion.Id">@inscripcion.Persona.NombreCompleto</a>
                            </td>
                            <td>@inscripcion.Persona.TipoIdentificacion.Humanize() — @inscripcion.Persona.NumeroIdentificacion</td>
                            <td>@inscripcion.Localidad</td>
                            <td><span class="badge @badgePago">@textoPago</span></td>
                            <td>@(inscripcion.RequiereHospedaje ? "Sí" : "No")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="pagination">
            <div class="pagination__info">
                Mostrando @((Model.Pagina - 1) * Model.PorPagina + 1)–@(Math.Min(Model.Pagina * Model.PorPagina,
                                                                                                                                                                Model.TotalInscripciones)) de @Model.TotalInscripciones
            </div>
            <div class="pagination__controls">
                @if (Model.Pagina > 1)
                {
                    <a href="@Model.BuildPageUrl(Model.Pagina - 1)" class="btn btn--secondary">← Anterior</a>
                }
                <span class="pagination__current">Página @Model.Pagina de @Model.TotalPaginas</span>
                @if (Model.Pagina < Model.TotalPaginas)
                {
                    <a href="@Model.BuildPageUrl(Model.Pagina + 1)" class="btn btn--secondary">Siguiente →</a>
                }
            </div>
            <div class="pagination__size">
                @foreach (var size in new[] { 10, 50, 100 })
                {
                    if (size == Model.PorPagina)
                    {
                        <span class="btn btn--primary">@size</span>
                    }
                    else
                    {
                        <a href="@Model.BuildPageUrl(1, size)" class="btn btn--secondary">@size</a>
                    }
                }
            </div>
        </div>
    }

    <form method="get" action="/admin/inscripciones" class="card filter-form" style="margin-top:1rem;">
        <h4 style="margin-bottom: 14px;">Busqueda</h4>
        @if (!string.IsNullOrEmpty(Model.SortLocalidad))
        {
            <input type="hidden" name="sortLocalidad" value="@Model.SortLocalidad" />
        }
        <div class="filter-grid">
            <div>
                <label class="form-label">Nombre</label>
                <input type="text" name="nombre" value="@Model.FiltroNombre" placeholder="Buscar por nombre..."
                       class="form-control" />
            </div>
            <div>
                <label class="form-label">Nº Documento</label>
                <input type="text" name="documento" value="@Model.FiltroDocumento" placeholder="Buscar por documento..."
                       class="form-control" />
            </div>
            <div>
                <label class="form-label">Localidad</label>
                <select name="departamento" id="filtroDepartamento" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var dep in Model.Departamentos)
                    {
                        <option value="@dep" selected="@(Model.FiltroDepartamento == dep)">@dep</option>
                    }
                </select>
            </div>
            <div>
                <label class="form-label">Municipio</label>
                <select name="municipio" id="filtroMunicipio" class="form-control">
                    <option value="">Todos</option>
                    @foreach (var ciudad in Model.Ciudades)
                    {
                        <option value="@ciudad" selected="@(Model.FiltroMunicipio == ciudad)">@ciudad</option>
                    }
                </select>
            </div>
            <div class="filter-actions">
                <button type="submit" class="btn btn--primary">Buscar</button>
                <a href="/admin/inscripciones" class="btn btn--secondary">Limpiar</a>
            </div>
        </div>
    </form>

<script>
    document.getElementById('filtroDepartamento').addEventListener('change', async function () {
        const municipioSelect = document.getElementById('filtroMunicipio');
        municipioSelect.innerHTML = '<option value="">Todos</option>';

        const departamento = this.value;
        if (!departamento) return;

        const response = await fetch(`/api/ubicacion/ciudades?departamento=${encodeURIComponent(departamento)}`);
        if (!response.ok) return;

        const ciudades = await response.json();
        ciudades.forEach(ciudad => {
            const option = document.createElement('option');
            option.value = ciudad;
            option.textContent = ciudad;
            municipioSelect.appendChild(option);
        });
    });
</script>
