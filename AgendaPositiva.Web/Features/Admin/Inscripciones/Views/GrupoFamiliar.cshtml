@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Inscripciones.Dominio;
@model GrupoFamiliar

<a href="javascript:history.back()" class="back-link">← Volver</a>

<h1 class="detail-title">Grupo Familiar #@Model.Id</h1>
<p class="text-secondary grupo-subtitle">@Model.Inscripciones.Count miembro(s)</p>

<div class="table-wrapper">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nombre</th>
                <th>Identificación</th>
                <th>Relación</th>
                <th>Estado</th>
                <th>Hospedaje</th>
                <th>Necesidades Especiales</th>
                <th>Comunión</th>
                <th>Alimentación</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (inscripcion, index) in Model.Inscripciones.Select((i, idx) => (i, idx)))
            {
                var badgeCss = inscripcion.Estado switch
                {
                    EstadoInscripcion.Completado => "badge--success",
                    EstadoInscripcion.Abono2 => "badge--abono2",
                    EstadoInscripcion.Abono1 => "badge--abono1",
                    EstadoInscripcion.Pendiente => "badge--warning",
                    EstadoInscripcion.NoVaAsistir => "badge--danger",
                    _ => "badge--muted"
                };
                <tr>
                    <td class="col-index">@(index + 1)</td>
                    <td class="col-name">
                        <a href="/admin/inscripciones/@inscripcion.Id">@inscripcion.Persona.NombreCompleto</a>
                    </td>
                    <td>@inscripcion.Persona.TipoIdentificacion.Humanize() — @inscripcion.Persona.NumeroIdentificacion</td>
                    <td>
                        @if (inscripcion.Relacion.HasValue && inscripcion.RelacionConPersona is not null)
                        {
                            @($"{inscripcion.Relacion.Value.Humanize()} de {inscripcion.RelacionConPersona.NombreCompleto}")
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td><span class="badge @badgeCss">@inscripcion.Estado.Humanize()</span></td>
                    <td>@(inscripcion.RequiereHospedaje ? "Sí" : "No")</td>
                    <td>@(string.IsNullOrEmpty(inscripcion.NecesidadesEspeciales) ? "—" : inscripcion.NecesidadesEspeciales)
                    </td>
                    <td>@(inscripcion.ParticipaComunionAncianos ? "Sí" : "No")</td>
                    <td>@(inscripcion.RequiereAlimentacion ? "Sí" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
