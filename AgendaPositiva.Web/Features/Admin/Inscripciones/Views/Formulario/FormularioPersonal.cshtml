@using AgendaPositiva.Web.Features.Admin.Inscripciones.Views.ViewModels;

@section Header {
    <nav class="breadcrumb">
        <a href="/admin/inscripciones">Inscripciones</a>
        <span class="breadcrumb__separator">/</span>
        <a href="/admin/inscripciones/formulario/verificacion">Verificación</a>
        <span class="breadcrumb__separator">/</span>
        <span class="breadcrumb__current">Formulario</span>
    </nav>
    <hgroup>
        <h1>Formulario de Inscripción</h1>
        <p>@ViewBag.NombreEvento</p>
    </hgroup>
}

<form action="/admin/inscripciones/formulario/formulario-personal" method="post">

    @if (ViewBag.Error is string error)
    {
        <div class="form-error">@error</div>
    }

    @await Html.PartialAsync("~/Features/Admin/Inscripciones/Views/Formulario/_PersonaFields.cshtml", new
    PersonaFieldsViewModel
    {
        Prefix = "",
        IdentificacionHabilitada = true,
        TipoIdentificacion = Model.TipoIdentificacion.ToString(),
        NumeroIdentificacion = Model.NumeroIdentificacion.ToString(),
        MostrarRelacion = false,
        DepartamentosDisponibles = ViewBag.DepartamentosDisponibles as List<string>
    })

    <div class="btn-group">
        <button type="submit" name="accion" value="continuar" class="btn btn--primary">Continuar</button>
    </div>

</form>