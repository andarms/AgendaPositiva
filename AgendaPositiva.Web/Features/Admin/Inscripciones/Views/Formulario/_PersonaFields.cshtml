@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Admin.Inscripciones.Views.ViewModels;
@using AgendaPositiva.Web.Features.Inscripciones.Dominio;
@model PersonaFieldsViewModel
@inject UbicacionService Ubicacion
@{
    string prefix = Model.Prefix;
    string dot = string.IsNullOrEmpty(prefix) ? "" : ".";
    string name(string field) => $"{prefix}{dot}{field}";
    string id(string field) => name(field).Replace(".", "_").Replace("[", "_").Replace("]", "_");
    var departamentos = Model.DepartamentosDisponibles ?? Ubicacion.ObtenerNombresDepartamentos();
}

<div class="form-grid">

    <div class="form-control form-grid__half">
        <label for="@id("Nombres")">Nombres: <span class="required">*</span></label>
        <input type="text" id="@id("Nombres")" name="@name("Nombres")" required>
    </div>

    <div class="form-control form-grid__half">
        <label for="@id("Apellidos")">Apellidos: <span class="required">*</span></label>
        <input type="text" id="@id("Apellidos")" name="@name("Apellidos")" required>
    </div>

    <div class="form-control">
        <label for="@id("Genero")">Sexo: <span class="required">*</span></label>
        <select id="@id("Genero")" name="@name("Genero")" required>
            @foreach (Genero genero in Enum.GetValues<Genero>())
            {
                <option value="@genero">@genero.Humanize()</option>
            }
        </select>
    </div>

    <div class="form-control">
        <label for="@id("TipoIdentificacion")">Tipo de Identificación: <span class="required">*</span></label>
        @if (Model.IdentificacionHabilitada)
        {
            <select id="@id("TipoIdentificacion")" disabled>
                @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
                {
                    <option value="@tipo" selected="@(tipo.ToString() == Model.TipoIdentificacion)">@tipo.Humanize()</option>
                }
            </select>
            <input type="hidden" name="@name("TipoIdentificacion")" value="@Model.TipoIdentificacion">
        }
        else
        {
            <select id="@id("TipoIdentificacion")" name="@name("TipoIdentificacion")" required>
                @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
                {
                    <option value="@tipo">@tipo.Humanize()</option>
                }
            </select>
        }
    </div>

    <div class="form-control">
        <label for="@id("NumeroIdentificacion")">Número de Identificación: <span class="required">*</span></label>
        @if (Model.IdentificacionHabilitada)
        {
            <input type="text" inputmode="numeric" id="@id("NumeroIdentificacion")" disabled
                   value="@Model.NumeroIdentificacion" required>
            <input type="hidden" name="@name("NumeroIdentificacion")" value="@Model.NumeroIdentificacion">
        }
        else
        {
            <input type="text" inputmode="numeric" id="@id("NumeroIdentificacion")" name="@name("NumeroIdentificacion")"
                   required>
        }
    </div>

    <div class="form-control">
        <label for="@id("FechaNacimiento")">Fecha de Nacimiento: <span class="required">*</span></label>
        <input type="date" id="@id("FechaNacimiento")" name="@name("FechaNacimiento")" min="1900-01-01"
               max="@DateOnly.FromDateTime(DateTime.Now).ToString("yyyy-MM-dd")" required>
    </div>

    <div class="form-control">
        <label for="@id("Telefono")">Teléfono: <span class="required">*</span></label>
        <input type="tel" id="@id("Telefono")" name="@name("Telefono")" pattern="[0-9]+" inputmode="numeric"
               oninput="this.value=this.value.replace(/[^0-9]/g,'')" required>
    </div>

    <div class="form-control">
        <label for="@id("Email")">Correo Electrónico:</label>
        <input type="email" id="@id("Email")" name="@name("Email")">
    </div>

    <div class="form-control">
        <label for="@id("Departamento")">Departamento: <span class="required">*</span></label>
        <select id="@id("Departamento")" name="@name("Departamento")" required>
            <option value="">-- Seleccione --</option>
            @foreach (var dep in departamentos)
            {
                <option value="@dep" selected="@(dep == Model.DepartamentoDefault)">@dep</option>
            }
        </select>
    </div>

    <div class="form-control" id="@id("Ciudad")_container">
        <label for="@id("Ciudad")">Ciudad: <span class="required">*</span></label>
        <select id="@id("Ciudad")" name="@name("Ciudad")">
            <option value="">-- Seleccione --</option>
        </select>
        <input type="text" id="@id("Ciudad")_text" name="@name("Ciudad")" placeholder="Ej: Miami, Nueva York..."
               style="display:none">
    </div>

    <div class="form-control form-grid__full">
        <label for="@id("RequiereHospedaje")">¿Requiere hospedaje? <span class="required">*</span></label>
        <select id="@id("RequiereHospedaje")" name="@name("RequiereHospedaje")" required>
            <option value="">-- Seleccione --</option>
            <option value="true">Sí</option>
            <option value="false">No</option>
        </select>
    </div>

    <div class="form-control form-grid__full" id="@id("Servicios")_container" style="display:none">
        <label>Actualmente en su localidad está sirviendo en alguno de estos servicios?:</label>
        <div class="checkbox-group">
            @foreach (ServicioInscripcion servicio in Enum.GetValues<ServicioInscripcion>())
            {
                <label class="checkbox-option">
                    <input type="checkbox" name="@name("Servicios")" value="@servicio"> @servicio.Descripcion()
                </label>
            }
        </div>
    </div>

    <div class="form-control form-grid__full" id="@id("AlergiaAlimentaria")_container" style="display:none">
        <label for="@id("TieneAlergiaAlimentaria")">¿Presenta alguna intolerancia o alergia alimenticia? <span
            class="required">*</span></label>
            <select id="@id("TieneAlergiaAlimentaria")" name="@name("TieneAlergiaAlimentaria")" required>
                <option value="">-- Seleccione --</option>
                <option value="false">No</option>
                <option value="true">Sí</option>
            </select>
        </div>

        <div class="form-control form-grid__full" id="@id("DescripcionAlergia")_container" style="display:none">
            <label for="@id("DescripcionAlergia")">Describa cuál:</label>
            <input type="text" id="@id("DescripcionAlergia")" name="@name("DescripcionAlergia")"
                   placeholder="Describa la alergia o intolerancia...">
        </div>

        <div class="form-control form-grid__full" id="@id("ParticipaFvKids")_container" style="display:none">
            <label for="@id("PreguntasAdicionalesNino_ParticipaFvKids")">¿El niño participará de la conferencia de FV KIDS?
                <span class="required">*</span></label>
                <select id="@id("PreguntasAdicionalesNino_ParticipaFvKids")"
                        name="@name("PreguntasAdicionalesNino.ParticipaFvKids")" required>
                    <option value="">-- Seleccione --</option>
                    <option value="false">No</option>
                    <option value="true">Sí</option>
                </select>
            </div>

            <div class="form-control form-grid__full" id="@id("TipoSangre")_container" style="display:none">
                <label for="@id("PreguntasAdicionalesNino_TipoSangre")">Tipo de sangre: <span class="required">*</span></label>
                <select id="@id("PreguntasAdicionalesNino_TipoSangre")" name="@name("PreguntasAdicionalesNino.TipoSangre")"
                        required>
                    <option value="">-- Seleccione --</option>
                    @foreach (TipoSangre tipo in Enum.GetValues<TipoSangre>())
                    {
                        <option value="@tipo">@tipo.Descripcion()</option>
                    }
                </select>
            </div>

            <div class="form-control form-grid__full" id="@id("Eps")_container" style="display:none">
                <label for="@id("PreguntasAdicionalesNino_Eps")">EPS: <span class="required">*</span></label>
                <input type="text" id="@id("PreguntasAdicionalesNino_Eps")" name="@name("PreguntasAdicionalesNino.Eps")"
                       placeholder="Nombre de la EPS..." required>
            </div>

            <div class="form-control form-grid__full" id="@id("ComunionAncianos")_container" style="display:none">
                <label for="@id("ParticipaComunionAncianos")">¿Va a participar de la comunión de Ancianos, Diácono y
                    Diaconisa? <span class="required">*</span></label>
                    <select id="@id("ParticipaComunionAncianos")" name="@name("ParticipaComunionAncianos")" required>
                        <option value="">-- Seleccione --</option>
                        <option value="false">No</option>
                        <option value="true">Sí</option>
                    </select>
                </div>

                <div class="form-control form-grid__full" id="@id("RequiereAlimentacion")_container" style="display:none">
                    <label for="@id("RequiereAlimentacion")">¿Requiere usted el servicio de alimentación que ofrece la
                        conferencia? <span class="required">*</span></label>
                        <select id="@id("RequiereAlimentacion")" name="@name("RequiereAlimentacion")" required>
                            <option value="">-- Seleccione --</option>
                            <option value="false">No</option>
                            <option value="true">Sí</option>
                        </select>
                    </div>

                    <div class="form-control form-grid__full">
                        <label for="@id("NecesidadesEspeciales")"><strong>NECESIDADES ESPECIALES:</strong></label>
                        <p class="helpertext">Si usted o sus acompañantes utilizan silla de ruedas, tienen movilidad reducida, se
                            encuentran
                            en recuperación
                            médica, presentan alguna condición cognitiva o requieren algún apoyo adicional, por favor indíquelo aquí.
                            Esta
                            información nos ayudará a gestionar el hospedaje de la mejor manera posible y, cuando sea necesario,
                            procurar
                            que las personas que requieran apoyo puedan alojarse juntas. Las solicitudes se atenderán según
                            disponibilidad.
                        </p>
                        <textarea id="@id("NecesidadesEspeciales")" name="@name("NecesidadesEspeciales")"></textarea>
                    </div>

    

                </div>

                @if (Model.MostrarRelacion)
                {
                    <div class="form-control">
                        <label for="@id("Parentesco")">Parentesco: <span class="required">*</span></label>
                        <select id="@id("Parentesco")" name="@name("Parentesco")" required>
                            <option value="">-- Seleccione --</option>
                            @foreach (Parentesco rel in Enum.GetValues<Parentesco>())
                            {
                                <option value="@rel">@rel.Humanize()</option>
                            }
                        </select>
                    </div>
                }

                <script>
                    (function () {
                        var depSelect = document.getElementById('@id("Departamento")');
                        var ciudadSelect = document.getElementById('@id("Ciudad")');
                        var ciudadText = document.getElementById('@id("Ciudad")_text');
                        var ciudadContainer = document.getElementById('@id("Ciudad")_container');
                        if (!depSelect || !ciudadSelect) return;

                        var ciudadDefault = '@Model.CiudadDefault';
                        var internacional = '@AgendaPositiva.Web.Features.Inscripciones.Dominio.UbicacionService.Internacional';

                        function actualizarVisibilidad(dep) {
                            if (dep === internacional) {
                                ciudadSelect.style.display = 'none';
                                ciudadSelect.removeAttribute('required');
                                ciudadSelect.removeAttribute('name');
                                ciudadSelect.value = '';
                                ciudadText.style.display = '';
                                ciudadText.setAttribute('required', '');
                                ciudadText.setAttribute('name', '@name("Ciudad")');
                            } else {
                                ciudadSelect.style.display = '';
                                ciudadSelect.setAttribute('required', '');
                                ciudadSelect.setAttribute('name', '@name("Ciudad")');
                                ciudadText.style.display = 'none';
                                ciudadText.removeAttribute('required');
                                ciudadText.removeAttribute('name');
                                ciudadText.value = '';
                            }
                        }

                        function cargarCiudades(departamento, ciudadSel) {
                            ciudadSelect.innerHTML = '<option value="">-- Seleccione --</option>';
                            if (!departamento || departamento === internacional) return;
                            fetch('/api/ubicacion/ciudades?departamento=' + encodeURIComponent(departamento))
                                .then(function (r) { return r.json(); })
                                .then(function (ciudades) {
                                    ciudades.forEach(function (c) {
                                        var opt = document.createElement('option');
                                        opt.value = c;
                                        opt.textContent = c;
                                        if (c === ciudadSel) opt.selected = true;
                                        ciudadSelect.appendChild(opt);
                                    });
                                });
                        }

                        // Inicializar
                        actualizarVisibilidad(depSelect.value);
                        if (depSelect.value === internacional) {
                            ciudadText.value = ciudadDefault;
                        } else if (depSelect.value) {
                            cargarCiudades(depSelect.value, ciudadDefault);
                        }

                        depSelect.addEventListener('change', function () {
                            actualizarVisibilidad(this.value);
                            cargarCiudades(this.value, '');
                        });

                        // Mostrar servicios solo si la persona es mayor de 16 años
                        // Mostrar preguntas de alergia solo si la persona tiene entre 4 y 10 años
                        var fechaNacInput = document.getElementById('@id("FechaNacimiento")');
                        var serviciosContainer = document.getElementById('@id("Servicios")_container');
                        var alergiaContainer = document.getElementById('@id("AlergiaAlimentaria")_container');
                        var descripcionAlergiaContainer = document.getElementById('@id("DescripcionAlergia")_container');
                        var tieneAlergiaSelect = document.getElementById('@id("TieneAlergiaAlimentaria")');
                        var participaFvKidsContainer = document.getElementById('@id("ParticipaFvKids")_container');
                        var participaFvKidsSelect = document.getElementById('@id("PreguntasAdicionalesNino_ParticipaFvKids")');
                        var tipoSangreContainer = document.getElementById('@id("TipoSangre")_container');
                        var tipoSangreSelect = document.getElementById('@id("PreguntasAdicionalesNino_TipoSangre")');
                        var epsContainer = document.getElementById('@id("Eps")_container');
                        var epsInput = document.getElementById('@id("PreguntasAdicionalesNino_Eps")');
                        var comunionContainer = document.getElementById('@id("ComunionAncianos")_container');
                        var comunionSelect = document.getElementById('@id("ParticipaComunionAncianos")');
                        var alimentacionContainer = document.getElementById('@id("RequiereAlimentacion")_container');
                        var alimentacionSelect = document.getElementById('@id("RequiereAlimentacion")');

                        function calcularEdad(fechaNac) {
                            var hoy = new Date();
                            var edad = hoy.getFullYear() - fechaNac.getFullYear();
                            var m = hoy.getMonth() - fechaNac.getMonth();
                            if (m < 0 || (m === 0 && hoy.getDate() < fechaNac.getDate())) edad--;
                            return edad;
                        }

                        function actualizarServicios() {
                            if (!fechaNacInput.value) {
                                serviciosContainer.style.display = 'none';
                                alergiaContainer.style.display = 'none';
                                descripcionAlergiaContainer.style.display = 'none';
                                participaFvKidsContainer.style.display = 'none';
                                tipoSangreContainer.style.display = 'none';
                                epsContainer.style.display = 'none';
                                comunionContainer.style.display = 'none';
                                alimentacionContainer.style.display = 'none';
                                comunionSelect.value = '';
                                comunionSelect.removeAttribute('required');
                                tieneAlergiaSelect.removeAttribute('required');
                                participaFvKidsSelect.removeAttribute('required');
                                tipoSangreSelect.removeAttribute('required');
                                epsInput.removeAttribute('required');
                                alimentacionSelect.removeAttribute('required');
                                return;
                            }
                            var fechaNac = new Date(fechaNacInput.value + 'T00:00:00');
                            var edad = calcularEdad(fechaNac);
                            serviciosContainer.style.display = edad >= 16 ? '' : 'none';

                            // Comunión de ancianos: solo mayores de 18 años
                            var esMayorDeEdad = edad >= 18;
                            comunionContainer.style.display = esMayorDeEdad ? '' : 'none';
                            if (esMayorDeEdad) {
                                comunionSelect.setAttribute('required', '');
                            } else {
                                comunionSelect.value = '';
                                comunionSelect.removeAttribute('required');
                            }

                            // Alimentación: no se pregunta a bebés de 0 a 3 años
                            var esBebe = edad >= 0 && edad <= 3;
                            alimentacionContainer.style.display = esBebe ? 'none' : '';
                            if (!esBebe) {
                                alimentacionSelect.setAttribute('required', '');
                            } else {
                                alimentacionSelect.value = '';
                                alimentacionSelect.removeAttribute('required');
                            }

                            // Preguntas para niños de 4 a 10 años
                            var esNino4a10 = edad >= 4 && edad <= 10;
                            alergiaContainer.style.display = esNino4a10 ? '' : 'none';
                            participaFvKidsContainer.style.display = esNino4a10 ? '' : 'none';
                            tipoSangreContainer.style.display = esNino4a10 ? '' : 'none';
                            epsContainer.style.display = esNino4a10 ? '' : 'none';
                            if (esNino4a10) {
                                tieneAlergiaSelect.setAttribute('required', '');
                                participaFvKidsSelect.setAttribute('required', '');
                                tipoSangreSelect.setAttribute('required', '');
                                epsInput.setAttribute('required', '');
                            } else {
                                tieneAlergiaSelect.value = '';
                                tieneAlergiaSelect.removeAttribute('required');
                                participaFvKidsSelect.value = '';
                                participaFvKidsSelect.removeAttribute('required');
                                tipoSangreSelect.value = '';
                                tipoSangreSelect.removeAttribute('required');
                                epsInput.value = '';
                                epsInput.removeAttribute('required');
                                descripcionAlergiaContainer.style.display = 'none';
                            }
                            actualizarDescripcionAlergia();
                        }

                        function actualizarDescripcionAlergia() {
                            if (alergiaContainer.style.display !== 'none' && tieneAlergiaSelect && tieneAlergiaSelect.value === 'true') {
                                descripcionAlergiaContainer.style.display = '';
                            } else {
                                descripcionAlergiaContainer.style.display = 'none';
                            }
                        }

                        actualizarServicios();
                        fechaNacInput.addEventListener('change', actualizarServicios);
                        tieneAlergiaSelect.addEventListener('change', actualizarDescripcionAlergia);
                    })();
                </script>