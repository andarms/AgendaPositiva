@{
    ViewData["MainClass"] = "site-main--narrow";
}

<div class="narrow-container" style="text-align: center; padding: 3rem 1.5rem;">
    <h1 style="margin-bottom: 1rem;">Información no disponible</h1>
    <p style="color: #6e6e73; margin-bottom: 2rem;">
        Esta inscripción pertenece a una localidad a la que no tienes acceso asignado.
        Si crees que esto es un error, contacta a un administrador.
    </p>
    <a href="/admin/inscripciones/formulario/verificacion" class="btn btn--primary">Volver a verificación</a>
</div>
