@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Admin.Inscripciones.Views.ViewModels;
@model VerificarFamiliaresViewModel

@section Header {
    <nav class="breadcrumb">
        <a href="/admin/inscripciones">Inscripciones</a>
        <span class="breadcrumb__separator">/</span>
        <span class="breadcrumb__current">Familiares de @Model.NombrePersona</span>
    </nav>
    <h1>Grupo Familiar de @Model.NombrePersona</h1>
    <p class="small-text">
        Busca e inscribe a los familiares que acompañarán a <strong>@Model.NombrePersona</strong> en la conferencia.
        Esto permite gestionar mejor el hospedaje. No implica que compartirán alojamiento.
    </p>
}

@if (Model.PersonaEncontrada is not null)
{
    <div class="persona-encontrada">
        <p><strong>Persona encontrada:</strong></p>
        <div class="detail-card">
            <div class="detail-item detail-item--full">
                <div class="detail-item__label">Nombre</div>
                <div class="detail-item__value">@Model.PersonaEncontrada.NombreCompleto</div>
            </div>
            <div class="detail-item">
                <div class="detail-item__label">Identificación</div>
                <div class="detail-item__value">
                    @Model.PersonaEncontrada.TipoIdentificacion.Humanize() -
                    @Model.PersonaEncontrada.NumeroIdentificacion</div>
                </div>
                <div class="detail-item">
                    <div class="detail-item__label">Género</div>
                    <div class="detail-item__value">@Model.PersonaEncontrada.Genero.Humanize()</div>
                </div>
                <div class="detail-item">
                    <div class="detail-item__label">Fecha de Nacimiento</div>
                    <div class="detail-item__value">@Model.PersonaEncontrada.FechaNacimiento.ToString("dd/MM/yyyy")</div>
                </div>
                <div class="detail-item">
                    <div class="detail-item__label">Teléfono</div>
                    <div class="detail-item__value">@Model.PersonaEncontrada.Telefono</div>
                </div>
                <div class="detail-item">
                    <div class="detail-item__label">Correo</div>
                    <div class="detail-item__value">@(Model.PersonaEncontrada.Email ?? "—")</div>
                </div>
            </div>
            <form action="/admin/inscripciones/formulario/agregar-familiar/@Model.InscripcionId" method="post">
                <input type="hidden" name="PersonaExistenteId" value="@Model.PersonaEncontrada.Id">
                <div class="form-control">
                    <label for="parentesco">Parentesco:</label>
                    <select id="parentesco" name="Parentesco" required>
                        <option value="">-- Seleccione --</option>
                        @foreach (Parentesco rel in Enum.GetValues<Parentesco>())
                        {
                            <option value="@rel">@rel.Humanize()</option>
                        }
                    </select>
                </div>
                <button class="btn btn--primary" type="submit">Guardar Cambios</button>
            </form>
            <div class="btn-group">
                <a href="/admin/inscripciones/formulario/verificar-familiares/@Model.InscripcionId"
                   class="btn btn--secondary">Cancelar</a>
            </div>
        </div>
    }
else
    {
        <p class="small-text">Busca al familiar por su documento de identidad. Si no está registrado(a), podrás llenar sus
            datos.</p>
            <form action="/admin/inscripciones/formulario/verificar-familiares/@Model.InscripcionId" method="post"
                  class="search-inline">
                <div class="form-control">
                    <label for="tipoIdentificacion">Tipo de Identificación:</label>
                    <select id="tipoIdentificacion" name="TipoIdentificacion" required>
                        @foreach (TipoIdentificacion tipo in Enum.GetValues<TipoIdentificacion>())
                        {
                            <option value="@tipo">@tipo.Humanize()</option>
                        }
                    </select>
                </div>
                <div class="form-control search-inline__input">
                    <label for="numeroIdentificacion">Número de Identificación:</label>
                    <input type="text" inputmode="numeric" id="numeroIdentificacion" name="NumeroIdentificacion" required>
                </div>
                <button class="btn btn--secondary" type="submit">Buscar</button>
            </form>
        }

        <hr />

        @if (Model.FamiliaresAgregados.Count > 0)
        {
            <h2>Grupo Familiar</h2>
            @foreach (var familiar in Model.FamiliaresAgregados)
            {
                <div class="detail-card">
                    <div class="detail-item detail-item--full">
                        <div class="detail-item__label">Nombre</div>
                        <div class="detail-item__value">@familiar.Persona.NombreCompleto</div>
                    </div>
                    @if (familiar.Relacion is not null)
                    {
                        <div class="detail-item detail-item--full">
                            <div class="detail-item__label">Relación</div>
                            <div class="detail-item__value">@familiar.Relacion?.Humanize() de @familiar.RelacionConPersona?.NombreCompleto
                            </div>
                        </div>
                    }
                </div>
            }
        }

        @if (Model.PersonaEncontrada is null)
        {
            <div class="btn-group">
                <a href="/admin/inscripciones/@Model.InscripcionId" class="btn btn--primary">
                    @(Model.FamiliaresAgregados.Count > 0 ? "Listo, terminar pre-inscripción" : "Continuar sin agregar familiares")
                </a>
            </div>
        }