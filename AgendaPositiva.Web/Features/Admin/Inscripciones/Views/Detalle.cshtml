@using AgendaPositiva.Web.Features.Commons.Views;
@using AgendaPositiva.Web.Features.Commons;
@using AgendaPositiva.Web.Features.Inscripciones.Dominio;
@using AgendaPositiva.Web.Features.Admin.Auditoria;
@model Inscripcion

@{
    var badgeCss = Model.Estado switch
    {
        EstadoInscripcion.Completado => "badge--success",
        EstadoInscripcion.Abono2 => "badge--abono2",
        EstadoInscripcion.Abono1 => "badge--abono1",
        EstadoInscripcion.Pendiente => "badge--warning",
        EstadoInscripcion.NoVaAsistir => "badge--danger",
        _ => "badge--muted"
    };

    var edad = DateTime.Today.Year - Model.Persona.FechaNacimiento.Year;
    if (DateOnly.FromDateTime(DateTime.Today) < Model.Persona.FechaNacimiento.AddYears(edad))
        edad--;
}

@section Styles {
    <style>
        .detalle-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            flex-wrap: wrap;
            margin-top: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .detalle-header__info h1 {
            font-size: 1.625rem;
            margin-bottom: 0.25rem;
        }

        .detalle-header__meta {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: #6e6e73;
            font-size: 0.8125rem;
        }

        .detalle-header__meta .badge {
            font-size: 0.75rem;
        }

        .detalle-header__actions {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .detail-section-title {
            font-size: 0.6875rem;
            font-weight: 600;
            color: #86868b;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 0.75rem;
            padding-bottom: 0.5rem;
            border-bottom: 1px solid rgba(0, 0, 0, 0.06);
        }

        .detail-value {
            font-size: 0.875rem;
            color: #1d1d1f;
        }

        .detail-value--muted {
            color: #86868b;
            font-style: italic;
        }

        .servicios-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 0.375rem;
        }

        .servicio-tag {
            display: inline-block;
            padding: 0.2rem 0.625rem;
            border-radius: 100px;
            font-size: 0.6875rem;
            font-weight: 500;
            background: #e8e8f0;
            color: #1d1d1f;
        }

        .indicator {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            font-size: 0.8125rem;
        }

        .indicator__dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .indicator__dot--yes {
            background: #34c759;
        }

        .indicator__dot--no {
            background: #d1d1d6;
        }

        .admin-actions-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.25rem;
            margin-top: 1.5rem;
        }

        @@media (max-width: 768px) {
            .admin-actions-grid {
                grid-template-columns: 1fr;
            }
        }

        .admin-action-card {
            background: #fff;
            border: 1px solid rgba(0, 0, 0, 0.06);
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
        }

        .admin-action-card h3 {
            font-size: 0.8125rem;
            font-weight: 600;
            color: #1d1d1f;
            margin-bottom: 0.75rem;
        }

        .detalle-info-extra {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.25rem;
            margin-top: 1.25rem;
        }

        @@media (max-width: 768px) {
            .detalle-info-extra {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<a href="/admin/inscripciones" class="back-link">← Volver a inscripciones</a>

<div class="detalle-header">
    <div class="detalle-header__info">
        <h1>@Model.Persona.NombreCompleto</h1>
        <div class="detalle-header__meta">
            <span class="badge @badgeCss">@Model.Estado.Humanize()</span>
            <span>Inscripción #@Model.Id</span>
            <span>·</span>
            <span>@Model.Localidad</span>
            <span>·</span>
            <span>Registrado @Model.FechaCreacion.ToString("dd MMM yyyy, HH:mm")</span>
        </div>
    </div>
    @if (Model.GrupoFamiliar is not null)
    {
        <div class="detalle-header__actions">
            <a href="/admin/inscripciones/grupo/@Model.GrupoFamiliarId" class="btn btn--secondary">
                Grupo familiar #@Model.GrupoFamiliar.Id
            </a>
        </div>
    }
</div>

<div class="detail-grid">
    @* ── Datos personales ── *@
    <div class="card">
        <div class="detail-section-title">Datos personales</div>
        <div class="detail-fields">
            <div>
                <span class="field-label">Nombres</span>
                <span class="detail-value"><strong>@Model.Persona.Nombres</strong></span>
            </div>
            <div>
                <span class="field-label">Apellidos</span>
                <span class="detail-value"><strong>@Model.Persona.Apellidos</strong></span>
            </div>
            <div>
                <span class="field-label">Género</span>
                <span class="detail-value">@Model.Persona.Genero.Humanize()</span>
            </div>
            <div>
                <span class="field-label">Edad</span>
                <span class="detail-value">@edad años (@Model.Persona.FechaNacimiento.ToString("dd/MM/yyyy"))</span>
            </div>
            <div>
                <span class="field-label">Identificación</span>
                <span class="detail-value">@Model.Persona.TipoIdentificacion.Humanize() —
                    @Model.Persona.NumeroIdentificacion</span>
                </div>
                <div>
                    <span class="field-label">Teléfono</span>
                    <span class="detail-value">@Model.Persona.Telefono</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Persona.Email))
                {
                    <div class="field-span2">
                        <span class="field-label">Email</span>
                        <span class="detail-value">@Model.Persona.Email</span>
                    </div>
                }
                @if (Model.Relacion.HasValue && Model.RelacionConPersona is not null)
                {
                    <div class="field-span2">
                        <span class="field-label">Relación familiar</span>
                        <span class="detail-value">@Model.Relacion.Value.Humanize() de
                            @Model.RelacionConPersona.NombreCompleto</span>
                        </div>
                    }
                </div>
            </div>

            @* ── Inscripción y servicios ── *@
            <div class="card">
                <div class="detail-section-title">Inscripción</div>
                <div class="detail-fields">
                    <div>
                        <span class="field-label">Hospedaje</span>
                        <span class="indicator">
                            <span
                            class="indicator__dot @(Model.RequiereHospedaje ? "indicator__dot--yes" : "indicator__dot--no")"></span>
                            @(Model.RequiereHospedaje ? "Sí requiere" : "No requiere")
                        </span>
                    </div>
                    <div>
                        <span class="field-label">Alimentación</span>
                        <span class="indicator">
                            <span
                            class="indicator__dot @(Model.RequiereAlimentacion ? "indicator__dot--yes" : "indicator__dot--no")"></span>
                            @(Model.RequiereAlimentacion ? "Sí requiere" : "No requiere")
                        </span>
                    </div>
                    <div>
                        <span class="field-label">Comunión Ancianos/Diácono/Diaconisa</span>
                        <span class="indicator">
                            <span
                            class="indicator__dot @(Model.ParticipaComunionAncianos ? "indicator__dot--yes" : "indicator__dot--no")"></span>
                            @(Model.ParticipaComunionAncianos ? "Sí participa" : "No participa")
                        </span>
                    </div>
                    <div>
                        <span class="field-label">Alergia alimentaria</span>
                        @if (Model.TieneAlergiaAlimentaria)
                        {
                            <span class="indicator">
                                <span class="indicator__dot indicator__dot--yes"></span>
                                Sí — @(string.IsNullOrEmpty(Model.DescripcionAlergia) ? "Sin descripción" :
                                                                                    Model.DescripcionAlergia)
                            </span>
                        }
                        else
                        {
                            <span class="indicator">
                                <span class="indicator__dot indicator__dot--no"></span>
                                Ninguna
                            </span>
                        }
                    </div>
                    <div class="field-span2">
                        <span class="field-label">Necesidades especiales</span>
                        @if (string.IsNullOrEmpty(Model.NecesidadesEspeciales))
                        {
                            <span class="detail-value detail-value--muted">Ninguna</span>
                        }
                        else
                        {
                            <span class="detail-value">@Model.NecesidadesEspeciales</span>
                        }
                    </div>
                    @if (Model.Servicios.Count > 0)
                    {
                        <div class="field-span2">
                            <span class="field-label">Servicios</span>
                            <div class="servicios-tags">
                                @foreach (var servicio in Model.Servicios)
                                {
                                    <span class="servicio-tag">@servicio.Descripcion()</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ── Grupo familiar ── *@
        @if (Model.GrupoFamiliar is not null && Model.GrupoFamiliar.Inscripciones.Count > 0)
        {
            var familiares = Model.GrupoFamiliar.Inscripciones
                .Where(i => i.Id != Model.Id)
                .ToList();

            <div class="card" style="margin-top: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                    <div class="detail-section-title" style="margin-bottom: 0; padding-bottom: 0; border-bottom: none;">
                        Grupo Familiar #@Model.GrupoFamiliar.Id
                        <span style="font-weight: 400; color: #86868b; text-transform: none; letter-spacing: normal;">
                            — @Model.GrupoFamiliar.Inscripciones.Count miembro(s)
                        </span>
                    </div>
                    <div style="display: flex; gap: 0.5rem;">
                        <a href="/admin/inscripciones/formulario/verificar-familiares/@Model.Id" class="btn btn--primary"
                           style="font-size: 0.8125rem; padding: 0.4rem 1rem;">
                            + Agregar familiar
                        </a>
                        <a href="/admin/inscripciones/grupo/@Model.GrupoFamiliarId" class="btn btn--secondary"
                           style="font-size: 0.8125rem; padding: 0.4rem 1rem;">
                            Ver grupo completo
                        </a>
                    </div>
                </div>

                @if (familiares.Count > 0)
                {
                    <div class="table-wrapper" style="border: none; border-radius: 0;">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Nombre</th>
                                    <th>Identificación</th>
                                    <th>Relación</th>
                                    <th>Estado</th>
                                    <th>Hospedaje</th>
                                    <th>Alimentación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var familiar in familiares)
                                {
                                    var familiarBadge = familiar.Estado switch
                                    {
                                        EstadoInscripcion.Completado => "badge--success",
                                        EstadoInscripcion.Abono2 => "badge--abono2",
                                        EstadoInscripcion.Abono1 => "badge--abono1",
                                        EstadoInscripcion.Pendiente => "badge--warning",
                                        EstadoInscripcion.NoVaAsistir => "badge--danger",
                                        _ => "badge--muted"
                                    };
                                    <tr>
                                        <td class="col-name">
                                            <a href="/admin/inscripciones/@familiar.Id">@familiar.Persona.NombreCompleto</a>
                                        </td>
                                        <td>@familiar.Persona.TipoIdentificacion.Humanize() — @familiar.Persona.NumeroIdentificacion</td>
                                        <td>
                                            @if (familiar.Relacion.HasValue && familiar.RelacionConPersona is not null)
                                            {
                                                @($"{familiar.Relacion.Value.Humanize()} de {familiar.RelacionConPersona.NombreCompleto}")
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td><span class="badge @familiarBadge">@familiar.Estado.Humanize()</span></td>
                                        <td>@(familiar.RequiereHospedaje ? "Sí" : "No")</td>
                                        <td>@(familiar.RequiereAlimentacion ? "Sí" : "No")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p style="color: #86868b; font-size: 0.875rem; margin-top: 0.5rem;">
                        Esta persona es el único miembro del grupo familiar.
                    </p>
                }
            </div>
        }
        else
        {
            <div class="card" style="margin-top: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div class="detail-section-title" style="margin-bottom: 0; padding-bottom: 0; border-bottom: none;">
                        Grupo Familiar
                    </div>
                    <a href="/admin/inscripciones/formulario/verificar-familiares/@Model.Id" class="btn btn--primary"
                       style="font-size: 0.8125rem; padding: 0.4rem 1rem;">
                        + Agregar familiar
                    </a>
                </div>
                <p style="color: #86868b; font-size: 0.875rem; margin-top: 0.75rem;">
                    Esta inscripción no tiene grupo familiar asignado.
                </p>
            </div>
        }

        @* ── Acciones admin ── *@
        @if (User.IsInRole("Administrador"))
        {
            <div class="admin-actions-grid">
                <div class="admin-action-card">
                    <h3>Cambiar estado</h3>
                    <form method="post" action="/admin/inscripciones/@Model.Id/cambiar-estado" class="cambiar-estado__form">
                        <select name="nuevoEstado" class="form-control" style="width: auto;">
                            @foreach (EstadoInscripcion estado in Enum.GetValues<EstadoInscripcion>())
                            {
                                <option value="@estado" selected="@(Model.Estado == estado)">@estado.Humanize()</option>
                            }
                        </select>
                        <button type="submit" class="btn btn--primary">Guardar</button>
                    </form>
                </div>
                <div class="admin-action-card">
                    <h3>Cambiar hospedaje</h3>
                    <form method="post" action="/admin/inscripciones/@Model.Id/cambiar-hospedaje" class="cambiar-estado__form">
                        <select name="requiereHospedaje" class="form-control" style="width: auto;">
                            <option value="true" selected="@Model.RequiereHospedaje">Sí</option>
                            <option value="false" selected="@(!Model.RequiereHospedaje)">No</option>
                        </select>
                        <button type="submit" class="btn btn--primary">Guardar</button>
                    </form>
                </div>
            </div>
        }

        @* ── Historial de auditoría ── *@
        @{
            var auditoria = ViewBag.Auditoria as List<AuditoriaAdmin> ?? [];
        }
        @if (auditoria.Count > 0)
        {
            <div class="card" style="margin-top: 1.5rem;">
                <div class="detail-section-title">Historial de cambios</div>

                <div class="table-wrapper" style="border: none; border-radius: 0;">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Usuario</th>
                                <th>Acción</th>
                                <th>Anterior</th>
                                <th>Nuevo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var registro in auditoria)
                            {
                                <tr>
                                    <td class="col-date">@registro.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@registro.Usuario</td>
                                    <td>@registro.Accion</td>
                                    <td>@(registro.ValorAnterior ?? "—")</td>
                                    <td>@(registro.ValorNuevo ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
