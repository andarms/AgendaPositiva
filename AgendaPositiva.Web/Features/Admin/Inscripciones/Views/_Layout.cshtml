<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
          rel="stylesheet">
    <title>Admin — Agenda Positiva</title>
    <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Montserrat', system-ui, -apple-system, sans-serif;
                background: #f5f5f5;
                color: #333;
            }

            .admin-header {
                background: #1a1a2e;
                color: #fff;
                padding: 1rem 2rem;
                display: flex;
                align-items: center;
                gap: 1.5rem;
            }

            .admin-header h1 {
                font-size: 1.2rem;
                font-weight: 600;
            }

            .admin-header nav {
                display: flex;
                gap: 1rem;
            }

            .admin-header nav a {
                color: #ccc;
                text-decoration: none;
                font-size: 0.9rem;
            }

            .admin-header nav a:hover {
                color: #fff;
            }

            .admin-header__user {
                margin-left: auto;
                display: flex;
                align-items: center;
                gap: .75rem;
                font-size: 0.85rem;
                color: #ccc;
            }

            .admin-header__user span {
                font-weight: 500;
            }

            .admin-header__logout {
                background: none;
                border: 1px solid rgba(255, 255, 255, .25);
                color: #fff;
                padding: .35rem .75rem;
                border-radius: 4px;
                font-family: 'Montserrat', sans-serif;
                font-size: 0.8rem;
                font-weight: 500;
                cursor: pointer;
                transition: background .15s ease, border-color .15s ease;
            }

            .admin-header__logout:hover {
                background: rgba(255, 255, 255, .1);
                border-color: rgba(255, 255, 255, .5);
            }

            .admin-main {
                margin: 2rem auto;
                padding: 0 1rem;
            }

            .admin-footer {
                text-align: center;
                padding: 2rem;
                color: #999;
                font-size: 0.85rem;
            }
    </style>
    <link rel="stylesheet" href="/css/admin-inscripciones.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header class="admin-header">
        <h1>Adminitración</h1>
        <nav>
            <a href="/admin/inscripciones">Inscripciones</a>
            @if (User.IsInRole("Administrador"))
            {
                <a href="/admin/usuarios">Usuarios</a>
            }
        </nav>
        <div class="admin-header__user">
            <span>@User.Identity?.Name</span>
            <form method="post" action="/admin/auth/logout" style="margin:0;">
                <button type="submit" class="admin-header__logout">Cerrar sesión</button>
            </form>
        </div>
    </header>

    <main class="admin-main">
        @RenderBody()
    </main>

    <footer class="admin-footer">
        Panel de administración
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
