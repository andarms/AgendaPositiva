<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">
    <title>Admin — Agenda Positiva</title>
    <style>
            *,
            *::before,
            *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Montserrat', sans-serif;
                background: #f5f5f7;
                color: #1d1d1f;
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
                line-height: 1.5;
            }

            /* ── Header ── */
            .admin-header {
                padding: 0 1rem;
                height: 48px;
                display: flex;
                align-items: center;
                position: sticky;
                top: 0;
                z-index: 200;
                background: rgba(255, 255, 255, 0.8);
                backdrop-filter: saturate(180%) blur(20px);
                -webkit-backdrop-filter: saturate(180%) blur(20px);
                border-bottom: 0.5px solid rgba(0, 0, 0, 0.08);
            }

            @@media (min-width: 768px) {
                .admin-header {
                    padding: 0 2rem;
                }
            }

            .admin-header__brand {
                font-size: 0.8125rem;
                font-weight: 600;
                color: #1d1d1f;
                letter-spacing: -0.015em;
            }

            /* ── Hamburger ── */
            .admin-header__hamburger {
                display: flex;
                align-items: center;
                justify-content: center;
                background: none;
                border: none;
                padding: 0.375rem;
                margin-right: 0.5rem;
                cursor: pointer;
                border-radius: 6px;
                transition: background 0.15s ease;
                -webkit-tap-highlight-color: transparent;
            }

            .admin-header__hamburger:hover {
                background: rgba(0, 0, 0, 0.04);
            }

            .admin-header__hamburger svg {
                width: 20px;
                height: 20px;
                fill: #1d1d1f;
            }

            @@media (min-width: 768px) {
                .admin-header__hamburger {
                    display: none;
                }
            }

            .admin-header__user {
                margin-left: auto;
                display: flex;
                align-items: center;
                gap: 1rem;
                font-size: 0.75rem;
                color: #86868b;
            }

            .admin-header__user span {
                font-weight: 400;
                color: #86868b;
            }

            .admin-header__logout {
                background: none;
                border: none;
                color: #86868b;
                padding: 0.25rem 0;
                font-family: inherit;
                font-size: 0.75rem;
                font-weight: 400;
                cursor: pointer;
                transition: color 0.2s ease;
            }

            .admin-header__logout:hover {
                color: #1d1d1f;
            }

            /* ── Layout ── */
            .admin-layout {
                display: flex;
                min-height: calc(100vh - 48px);
            }

            /* ── Overlay ── */
            .admin-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.3);
                z-index: 299;
                -webkit-tap-highlight-color: transparent;
            }

            .admin-overlay.is-open {
                display: block;
            }

            @@media (min-width: 768px) {
                .admin-overlay {
                    display: none !important;
                }
            }

            /* ── Sidebar ── */
            .admin-sidebar {
                width: 200px;
                background: #fff;
                padding: 1.5rem 0.875rem;
                position: fixed;
                top: 48px;
                left: 0;
                height: calc(100vh - 48px);
                overflow-y: auto;
                flex-shrink: 0;
                z-index: 300;
                transform: translateX(-100%);
                transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
                border-right: 1px solid rgba(0, 0, 0, 0.06);
            }

            .admin-sidebar.is-open {
                transform: translateX(0);
            }

            @@media (min-width: 768px) {
                .admin-sidebar {
                    position: sticky;
                    transform: none;
                    background: transparent;
                    border-right: none;
                }
            }

            .admin-sidebar__label {
                font-size: 0.625rem;
                font-weight: 500;
                color: #86868b;
                text-transform: uppercase;
                letter-spacing: 0.08em;
                padding: 0 0.625rem;
                margin-bottom: 0.5rem;
            }

            .admin-sidebar nav {
                display: flex;
                flex-direction: column;
                gap: 1px;
            }

            .admin-sidebar nav a {
                color: #424245;
                text-decoration: none;
                font-size: 0.8125rem;
                font-weight: 400;
                padding: 0.4375rem 0.625rem;
                border-radius: 8px;
                transition: all 0.2s ease;
                display: block;
            }

            .admin-sidebar nav a:hover {
                color: #1d1d1f;
                background: rgba(0, 0, 0, 0.03);
            }

            .admin-sidebar nav a.active {
                color: #1d1d1f;
                font-weight: 500;
                background: rgba(0, 0, 0, 0.04);
                position: relative;
            }

            .admin-sidebar nav a.active::before {
                content: '';
                position: absolute;
                left: 0;
                top: 50%;
                transform: translateY(-50%);
                width: 3px;
                height: 16px;
                border-radius: 2px;
                background: #1d1d1f;
            }

            /* ── Content area ── */
            .admin-content {
                flex: 1;
                display: flex;
                flex-direction: column;
                min-width: 0;
            }

            .admin-main {
                flex: 1;
                padding: 1rem;
            }

            @@media (min-width: 768px) {
                .admin-main {
                    padding: 2rem;
                }
            }

            .admin-footer {
                text-align: center;
                padding: 2rem;
                color: #aeaeb2;
                font-size: 0.6875rem;
                font-weight: 400;
                letter-spacing: 0.01em;
            }
    </style>
    <link rel="stylesheet" href="/css/admin-inscripciones.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header class="admin-header">
        <button type="button" class="admin-header__hamburger" id="sidebar-toggle" aria-label="Abrir menú">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 6h18v2H3V6zm0 5h18v2H3v-2zm0 5h18v2H3v-2z" />
            </svg>
        </button>
        <span class="admin-header__brand">Agenda Positiva</span>
        <div class="admin-header__user">
            <span>@User.Identity?.Name</span>
            <form method="post" action="/admin/auth/logout" style="margin:0;">
                <button type="submit" class="admin-header__logout">Cerrar sesión</button>
            </form>
        </div>
    </header>

    @{
        var path = Context.Request.Path.ToString().ToLower();
    }
    <div class="admin-overlay" id="sidebar-overlay"></div>
    <div class="admin-layout">
        <aside class="admin-sidebar" id="admin-sidebar">
            <div class="admin-sidebar__label">Menú</div>
            <nav>
                <a href="/admin/inscripciones"
                   class="@(path.StartsWith("/admin/inscripciones") ? "active" : "")">Inscripciones</a>
                @if (User.IsInRole("Administrador"))
                {
                    <a href="/admin/usuarios" class="@(path.StartsWith("/admin/usuarios") ? "active" : "")">Usuarios</a>
                    <a href="/admin/auditoria" class="@(path.StartsWith("/admin/auditoria") ? "active" : "")">Auditoría</a>
                }
            </nav>
        </aside>

        <div class="admin-content">
            <main class="admin-main">
                @RenderBody()
            </main>

            <footer class="admin-footer">
                Agenda Positiva · Panel de administración
            </footer>
        </div>
    </div>

    <script>
            (function () {
                var toggle = document.getElementById('sidebar-toggle');
                var sidebar = document.getElementById('admin-sidebar');
                var overlay = document.getElementById('sidebar-overlay');

                function open() {
                    sidebar.classList.add('is-open');
                    overlay.classList.add('is-open');
                    toggle.setAttribute('aria-expanded', 'true');
                }

                function close() {
                    sidebar.classList.remove('is-open');
                    overlay.classList.remove('is-open');
                    toggle.setAttribute('aria-expanded', 'false');
                }

                toggle.addEventListener('click', function () {
                    sidebar.classList.contains('is-open') ? close() : open();
                });

                overlay.addEventListener('click', close);

                // Close on nav link click (mobile)
                sidebar.querySelectorAll('nav a').forEach(function (link) {
                    link.addEventListener('click', close);
                });
            })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
