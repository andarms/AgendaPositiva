@using AgendaPositiva.Web.Features.Inscripciones.Dominio
@model List<CategoriaInscripcion>

<nav class="breadcrumb">
    <a href="/admin">Admin</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">Categorías de Inscripción</span>
</nav>

<h1>Categorías de Inscripción</h1>

<div class="action-bar">
    <a href="/admin/categorias/crear" class="btn btn--primary btn--lg">+ Nueva Categoría</a>
</div>

@if (Model.Count == 0)
{
    <p>No hay categorías registradas.</p>
}
else
{
    <div class="table-wrapper">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cat in Model)
                {
                    <tr>
                        <td>@cat.Nombre</td>
                        <td>$@cat.Precio.ToString("N0")</td>
                        <td>
                            <span class="badge @(cat.Activa ? "badge--success" : "badge--danger")">
                                @(cat.Activa ? "Activa" : "Inactiva")
                            </span>
                        </td>
                        <td style="display:flex;gap:0.5rem;">
                            <a href="/admin/categorias/editar/@cat.Id" class="btn btn--secondary">Editar</a>
                            <form method="post" action="/admin/categorias/@cat.Id/toggle" style="display:inline;">
                                <button type="submit" class="btn @(cat.Activa ? "btn--danger" : "btn--success")">
                                    @(cat.Activa ? "Desactivar" : "Activar")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
