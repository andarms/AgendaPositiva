@using AgendaPositiva.Web.Features.Admin.Regiones
@using System.Text.Json
@model RegionFormViewModel

@{
    var esEdicion = Model.Id.HasValue;
    var titulo = esEdicion ? "Editar región" : "Nueva región";
    var action = esEdicion ? $"/admin/regiones/editar/{Model.Id}" : "/admin/regiones/crear";
}

@section Styles {
    <style>
        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .form-group {
            margin-bottom: 1.25rem;
        }

        .form-group label {
            display: block;
            font-size: 0.75rem;
            font-weight: 500;
            margin-bottom: 0.375rem;
            color: #6e6e73;
            letter-spacing: 0.01em;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 0.5rem 0.75rem;
            border: 1px solid rgba(0, 0, 0, 0.12);
            border-radius: 8px;
            font-size: 0.875rem;
            font-family: inherit;
            background: #fff;
            color: #1d1d1f;
            transition: border-color 0.15s ease, box-shadow 0.15s ease;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #0066cc;
            box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.12);
        }

        .localidades-section {
            max-height: 500px;
            overflow-y: auto;
            border: 1px solid rgba(0, 0, 0, 0.06);
            border-radius: 8px;
            background: #fafafa;
        }

        .localidades-actions {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 0.5rem;
        }

        .localidades-actions button {
            background: none;
            border: none;
            color: #0066cc;
            font-size: 0.8125rem;
            font-weight: 500;
            cursor: pointer;
            font-family: inherit;
        }

        .localidades-actions button:hover {
            color: #004499;
        }

        .depto-block {
            border-bottom: 1px solid rgba(0, 0, 0, 0.04);
        }

        .depto-block:last-child {
            border-bottom: none;
        }

        .depto-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.6rem 0.75rem;
            cursor: pointer;
            user-select: none;
            transition: background 0.1s ease;
        }

        .depto-header:hover {
            background: rgba(0, 0, 0, 0.02);
        }

        .depto-header input[type="checkbox"] {
            accent-color: #0066cc;
            width: 1rem;
            height: 1rem;
        }

        .depto-header .depto-name {
            font-size: 0.8125rem;
            font-weight: 600;
            color: #1d1d1f;
            flex: 1;
        }

        .depto-header .depto-badge {
            font-size: 0.6875rem;
            color: #86868b;
            background: rgba(0, 0, 0, 0.04);
            padding: 0.1rem 0.5rem;
            border-radius: 100px;
        }

        .depto-header .depto-toggle {
            font-size: 0.6875rem;
            color: #86868b;
            transition: transform 0.15s;
        }

        .depto-block.expanded .depto-toggle {
            transform: rotate(90deg);
        }

        .ciudades-panel {
            display: none;
            padding: 0.25rem 0.75rem 0.75rem 2.25rem;
            background: #fff;
        }

        .depto-block.expanded .ciudades-panel {
            display: block;
        }

        .ciudades-actions {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 0.35rem;
        }

        .ciudades-actions button {
            background: none;
            border: none;
            color: #0066cc;
            font-size: 0.75rem;
            cursor: pointer;
            font-family: inherit;
        }

        .ciudades-actions button:hover {
            color: #004499;
        }

        .ciudades-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 0.25rem;
        }

        .ciudad-item {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            font-size: 0.8125rem;
            color: #1d1d1f;
        }

        .ciudad-item input {
            accent-color: #0066cc;
            width: 0.85rem;
            height: 0.85rem;
        }

        .ciudades-note {
            font-size: 0.75rem;
            color: #86868b;
            font-style: italic;
            margin-bottom: 0.35rem;
        }

        .form-actions {
            display: flex;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .field-error {
            color: #ff3b30;
            font-size: 0.75rem;
            margin-top: 0.25rem;
        }
    </style>
}

<nav class="breadcrumb">
    <a href="/admin/regiones">Regiones</a>
    <span class="breadcrumb__separator">/</span>
    <span class="breadcrumb__current">@titulo</span>
</nav>

<div class="card">
    <h1>@titulo</h1>

    <form method="post" action="@action" id="region-form">
        <div class="form-row">
            <div class="form-group">
                <label for="Nombre">Nombre de la región</label>
                <input type="text" id="Nombre" name="Nombre" value="@Model.Nombre" required
                       placeholder="Ej: Bogotá, Costa Atlántica, etc." />
            </div>
            <div class="form-group">
                <label for="Cupo">Cupo de inscripciones</label>
                <input type="number" id="Cupo" name="Cupo" value="@Model.Cupo" min="0" required />
            </div>
        </div>

        <div class="form-group">
            <label>Localidades de la región</label>
            <div class="localidades-actions">
                <button type="button" onclick="toggleAllDeptos(true)">Seleccionar todos</button>
                <button type="button" onclick="toggleAllDeptos(false)">Deseleccionar todos</button>
            </div>
            <div class="localidades-section">
                @foreach (var depto in Model.DepartamentosInfo)
                {
                    var ciudadesJson = JsonSerializer.Serialize(depto.CiudadesDisponibles);
                    <div class="depto-block" data-depto="@depto.Nombre" data-ciudades="@ciudadesJson">
                        <div class="depto-header" onclick="toggleDepto(this)">
                            <input type="checkbox" class="depto-cb"
                                   onclick="event.stopPropagation(); onDeptoCbChange(this)" />
                            <span class="depto-name">@depto.Nombre</span>
                            @if (depto.CiudadesDisponibles.Count > 0)
                            {
                                <span class="depto-badge ciudades-count"></span>
                                <span class="depto-toggle">▶</span>
                            }
                        </div>
                        @if (depto.CiudadesDisponibles.Count > 0)
                        {
                            <div class="ciudades-panel">
                                <div class="ciudades-note">Sin ciudades seleccionadas = todas las ciudades del departamento
                                </div>
                                <div class="ciudades-actions">
                                    <button type="button" onclick="toggleCiudades(this, true)">Todas</button>
                                    <button type="button" onclick="toggleCiudades(this, false)">Ninguna</button>
                                </div>
                                <div class="ciudades-grid">
                                    @foreach (var ciudad in depto.CiudadesDisponibles)
                                    {
                                        <label class="ciudad-item">
                                            <input type="checkbox" class="ciudad-cb" value="@ciudad"
                                                   onchange="onCiudadChange(this)" />
                                            @ciudad
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <input type="hidden" name="LocalidadesJson" id="LocalidadesJson" value="@Model.LocalidadesJson" />

        <div class="form-actions">
            <button type="submit" class="btn btn--primary">@(esEdicion ? "Guardar cambios" : "Crear región")</button>
            <a href="/admin/regiones" class="btn btn--secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const localidadesData = JSON.parse(document.getElementById('LocalidadesJson').value || '{}');

        document.querySelectorAll('.depto-block').forEach(block => {
            const deptoName = block.dataset.depto;
            const deptoCb = block.querySelector('.depto-cb');
            if (localidadesData[deptoName] !== undefined) {
                deptoCb.checked = true;
                const ciudadesSeleccionadas = localidadesData[deptoName];
                if (ciudadesSeleccionadas.length > 0) {
                    block.querySelectorAll('.ciudad-cb').forEach(cb => {
                        cb.checked = ciudadesSeleccionadas.includes(cb.value);
                    });
                }
            }
            actualizarBadge(block);
        });

        function toggleDepto(header) {
            const block = header.closest('.depto-block');
            if (!block.querySelector('.ciudades-panel')) return;
            block.classList.toggle('expanded');
        }

        function onDeptoCbChange(cb) {
            const block = cb.closest('.depto-block');
            if (!cb.checked) {
                block.querySelectorAll('.ciudad-cb').forEach(c => c.checked = false);
                block.classList.remove('expanded');
            }
            actualizarBadge(block);
            sincronizarJson();
        }

        function onCiudadChange(cb) {
            const block = cb.closest('.depto-block');
            const deptoCb = block.querySelector('.depto-cb');
            const anyChecked = block.querySelectorAll('.ciudad-cb:checked').length > 0;
            if (anyChecked && !deptoCb.checked) deptoCb.checked = true;
            actualizarBadge(block);
            sincronizarJson();
        }

        function toggleCiudades(btn, checked) {
            const panel = btn.closest('.ciudades-panel');
            const block = panel.closest('.depto-block');
            panel.querySelectorAll('.ciudad-cb').forEach(cb => cb.checked = checked);
            if (checked) block.querySelector('.depto-cb').checked = true;
            actualizarBadge(block);
            sincronizarJson();
        }

        function toggleAllDeptos(checked) {
            document.querySelectorAll('.depto-cb').forEach(cb => {
                cb.checked = checked;
            });
            if (!checked) {
                document.querySelectorAll('.ciudad-cb').forEach(cb => cb.checked = false);
                document.querySelectorAll('.depto-block').forEach(b => b.classList.remove('expanded'));
            }
            document.querySelectorAll('.depto-block').forEach(actualizarBadge);
            sincronizarJson();
        }

        function actualizarBadge(block) {
            const badge = block.querySelector('.ciudades-count');
            if (!badge) return;
            const deptoCb = block.querySelector('.depto-cb');
            const total = block.querySelectorAll('.ciudad-cb').length;
            const selected = block.querySelectorAll('.ciudad-cb:checked').length;

            if (!deptoCb.checked) {
                badge.textContent = '';
            } else if (selected === 0) {
                badge.textContent = `Todas (${total})`;
            } else {
                badge.textContent = `${selected} de ${total}`;
            }
        }

        function sincronizarJson() {
            const result = {};
            document.querySelectorAll('.depto-block').forEach(block => {
                const deptoCb = block.querySelector('.depto-cb');
                if (!deptoCb.checked) return;

                const deptoName = block.dataset.depto;
                const ciudadesCbs = block.querySelectorAll('.ciudad-cb:checked');
                const ciudades = Array.from(ciudadesCbs).map(cb => cb.value);
                result[deptoName] = ciudades;
            });
            document.getElementById('LocalidadesJson').value = JSON.stringify(result);
        }

        // Sincronizar al enviar
        document.getElementById('region-form').addEventListener('submit', sincronizarJson);
    </script>
}
